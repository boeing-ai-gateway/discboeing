# Local development environment variables
# Copy this file to .env and fill in your values

# React Dev Tools (optional)
# Set this to the HTTP URL of your React Dev Tools server to enable it
# Example: http://localhost:8097
REACT_DEVTOOLS_URL=http://localhost:8097

# Sentry browser SDK (optional override for local builds)
# PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0
