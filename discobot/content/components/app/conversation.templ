package app

import (
	"strings"

	agentmessage "github.com/obot-platform/discobot/agent-go/message"
	"github.com/obot-platform/discobot/discobot/internal/state"
	serverapi "github.com/obot-platform/discobot/server/api"
)

templ Conversation(thread state.Thread) {
	if len(thread.Messages) > 0 {
		<div class="conversation" aria-label="Conversation" data-thread-id={ thread.ID }>
			@Messages(thread.Messages)
		</div>
	}
}

templ Messages(messages []serverapi.Message) {
	<div class="messages" aria-label="Messages">
		for _, message := range messages {
			<div class={ threadMessageClass(message.Role) }>
				<span class="messages--avatar">{ threadMessageAvatar(message.Role) }</span>
				<div class="messages--bubble">{ threadMessageText(message) }</div>
			</div>
		}
	</div>
}

func threadMessageClass(role string) string {
	class := "messages--message"
	if role == "user" {
		return class + " messages--message--user"
	}
	return class + " messages--message--assistant"
}

func threadMessageAvatar(role string) string {
	if role == "user" {
		return "U"
	}
	return "AI"
}

func threadMessageText(message serverapi.Message) string {
	var parts []string
	for _, part := range message.Parts {
		switch part := part.(type) {
		case agentmessage.UITextPart:
			if part.Text != "" {
				parts = append(parts, part.Text)
			}
		case agentmessage.UIReasoningPart:
			if part.Text != "" {
				parts = append(parts, part.Text)
			}
		}
	}
	return strings.Join(parts, "\n")
}
