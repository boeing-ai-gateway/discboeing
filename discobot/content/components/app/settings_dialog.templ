package app

import (
	"github.com/obot-platform/discobot/discobot/content/components/helpers"
	"strconv"

	"github.com/obot-platform/discobot/discobot/internal/state"
)

templ SettingsDialog(shell state.Shell) {
	if shell.View.Settings.Open {
		<div class="fixed inset-0 z-[100] grid place-items-center bg-black/55 p-6 [-webkit-app-region:no-drag]" role="presentation">
			<section class="flex max-h-[90vh] w-full max-w-2xl flex-col overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--background)] text-[var(--foreground)] shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="settings-dialog-title" aria-describedby="settings-dialog-description">
				<header class="flex items-start justify-between gap-4 border-b border-[var(--border)] p-5">
					<div class="space-y-1">
						<h2 id="settings-dialog-title" class="text-lg leading-none font-semibold">Settings</h2>
						<p id="settings-dialog-description" class="text-sm text-[var(--muted-foreground)]">Configure appearance, chat defaults, providers, updates, credentials, and support tools.</p>
					</div>
					<button type="button" class="grid h-8 w-8 shrink-0 place-items-center rounded-md text-[var(--muted-foreground)] hover:bg-[var(--tree-hover)] hover:text-[var(--foreground)]" aria-label="Close settings" data-on:click="@discobotCommand('/ui/commands/settings/close', {method: 'POST'})">
						@IconX("icon-sm")
					</button>
				</header>
				<div class="overflow-y-auto p-5">
					<nav class="grid grid-cols-5 rounded-lg bg-[var(--muted)] p-1 text-sm" aria-label="Settings sections">
						@settingsTabButton(shell.View.Settings.Tab, state.SettingsTabAppearance, "Appearance")
						@settingsTabButton(shell.View.Settings.Tab, state.SettingsTabChat, "Chat")
						@settingsTabButton(shell.View.Settings.Tab, state.SettingsTabProviders, "Providers")
						@settingsTabButton(shell.View.Settings.Tab, state.SettingsTabUpdate, "Update")
						@settingsTabButton(shell.View.Settings.Tab, state.SettingsTabCredentials, "Credentials")
					</nav>
					<div class="mt-3 min-h-[28rem]">
						if shell.View.Settings.Tab == state.SettingsTabAppearance {
							@settingsAppearanceTab()
						} else if shell.View.Settings.Tab == state.SettingsTabChat {
							@settingsChatTab()
						} else if shell.View.Settings.Tab == state.SettingsTabProviders {
							@settingsProvidersTab()
						} else if shell.View.Settings.Tab == state.SettingsTabUpdate {
			@settingsUpdateTab(shell.View.Settings.CacheCleared)
						} else if shell.View.Settings.Tab == state.SettingsTabCredentials {
							@settingsCredentialsTab()
						}
					</div>
				</div>
				<footer class="flex items-center justify-between gap-3 border-t border-[var(--border)] p-5">
					<button type="button" class="grid h-9 w-9 place-items-center rounded-md border border-[var(--border)] bg-[var(--surface-control)] text-[var(--foreground)] hover:bg-[var(--tree-hover)]" title="Support information" aria-label="Support information" data-on:click="@discobotCommand('/ui/commands/settings/support/open', {method: 'POST'})">
						@IconGear("icon-sm")
					</button>
					<button type="button" class="rounded-md bg-[var(--primary)] px-4 py-2 text-sm font-medium text-[var(--primary-foreground)] hover:opacity-90" data-on:click="@discobotCommand('/ui/commands/settings/close', {method: 'POST'})">Done</button>
				</footer>
			</section>
			if shell.View.Settings.SupportInfoOpen {
				@settingsSupportInfoDialog()
			}
			if shell.View.Settings.ClearCacheDialogOpen {
				@settingsClearCacheDialog()
			}
		</div>
	}
}

templ settingsTabButton(active state.SettingsTab, tab state.SettingsTab, label string) {
	<button type="button" class={ settingsTabButtonClass(active, tab) } aria-selected={ helpers.BoolString(active == tab) } data-on:click={ settingsTabCommand(tab) }>{ label }</button>
}

templ settingsAppearanceTab() {
	@settingsCard("Appearance", "Mode and color theme preferences.") {
		@settingsItem("Mode", "Resolved mode: dark") {
			<div class="inline-flex rounded-full border border-[var(--border)] bg-[var(--muted)] p-1 text-xs">
				<button type="button" class="rounded-full px-3 py-1 text-[var(--muted-foreground)]">Light</button>
				<button type="button" class="rounded-full border border-[var(--primary)] bg-[var(--primary)] px-3 py-1 text-[var(--primary-foreground)] shadow-sm">Dark</button>
				<button type="button" class="rounded-full px-3 py-1 text-[var(--muted-foreground)]">System</button>
			</div>
		}
		@settingsSeparator()
		@settingsItem("Theme", "Current palette: Default Dark") {
			<select class="h-9 w-56 rounded-md border border-[var(--border)] bg-[var(--surface-control)] px-3 text-sm dark:[color-scheme:dark]">
				<option>Default Dark</option>
				<option>Default Light</option>
				<option>Nord</option>
				<option>Tokyo Night</option>
				<option>Dracula</option>
				<option>Catppuccin Mocha</option>
				<option>Catppuccin Macchiato</option>
				<option>Catppuccin Frappé</option>
				<option>Flexoki Dark</option>
				<option>Solarized Light</option>
				<option>Flexoki Light</option>
				<option>Alucard</option>
				<option>Catppuccin Latte</option>
			</select>
		}
		@settingsSeparator()
		@settingsItem("Recent list size", "Choose how many recent threads appear in the sidebar.") {
			<div class="inline-flex rounded-full border border-[var(--border)] bg-[var(--muted)] p-1 text-xs">
				<button type="button" class="rounded-full px-3 py-1 text-[var(--muted-foreground)]">Off</button>
				<button type="button" class="rounded-full px-3 py-1 text-[var(--muted-foreground)]">3</button>
				<button type="button" class="rounded-full border border-[var(--primary)] bg-[var(--primary)] px-3 py-1 text-[var(--primary-foreground)] shadow-sm">5</button>
				<button type="button" class="rounded-full px-3 py-1 text-[var(--muted-foreground)]">10</button>
			</div>
		}
		@settingsSeparator()
		@settingsSwitchItem("Show refresh button", "Display a refresh button in the header bar.", true)
		@settingsSeparator()
		@settingsSwitchItem("Show editor button", "Display the embedded editor entry point in the session toolbar. Disabled by default.", false)
	}
}

templ settingsChatTab() {
	@settingsCard("Chat", "Conversation defaults for new prompts.") {
		@settingsItem("Default model", "Set a preferred model or keep auto-select.") {
			<select class="h-9 w-56 rounded-md border border-[var(--border)] bg-[var(--surface-control)] px-3 text-sm dark:[color-scheme:dark]">
				<option>Auto-select</option>
				<optgroup label="Anthropic">
					<option>Claude Sonnet 4.5</option>
					<option>Claude Opus 4.1</option>
				</optgroup>
				<optgroup label="OpenAI">
					<option>GPT-5.1 Codex</option>
					<option>GPT-5.1</option>
				</optgroup>
			</select>
		}
		@settingsSeparator()
		@settingsSwitchItem("Full width conversation", "Expand messages and composer to use full space.", false)
		@settingsSeparator()
		@settingsSwitchItem("Auto-scroll", "Automatically scroll to the bottom while the agent is streaming a response.", true)
	}
}

templ settingsProvidersTab() {
	@settingsCard("Sandbox Providers", "Configure sandbox provider instances and credential references.") {
		<div class="space-y-3 p-4">
			@settingsProviderRow("Docker", "Local container sandboxes", "Default")
			@settingsProviderRow("VZ", "macOS virtualized sandboxes", "Available")
			@settingsProviderRow("WSL", "Windows Linux sandboxes", "Available")
		</div>
	}
}

templ settingsUpdateTab(cacheCleared bool) {
	@settingsCard("Update", "Check, download, and install app updates.") {
		<div class="space-y-3 p-4">
			<div class="flex items-start justify-between gap-4 rounded-md border border-[var(--border)] bg-[var(--background)] p-3">
				<div class="space-y-1">
					<p class="text-sm font-medium">Track pre-releases</p>
					<p class="text-sm text-[var(--muted-foreground)]">Use the latest GitHub pre-release channel instead of stable releases.</p>
				</div>
				@settingsSwitch(false)
			</div>
			<div class="rounded-md border border-[var(--border)] bg-[var(--background)] p-3 text-sm text-[var(--muted-foreground)]">You're on the latest version.</div>
			<div class="rounded-md border border-[var(--destructive)]/30 bg-[var(--destructive)]/5 p-3">
				<div class="flex items-start justify-between gap-3">
					<div class="space-y-1">
						<p class="text-sm font-medium">Project cache</p>
						<p class="text-sm text-[var(--muted-foreground)]">Delete the Docker cache volume for this project and unknown containers attached to it. No other named volumes are removed.</p>
						if cacheCleared {
							<p class="text-sm text-[var(--foreground)]">Cache cleared. Sessions will restart when they are used again.</p>
						}
					</div>
					<button type="button" class="rounded-md bg-[var(--destructive)] px-3 py-1.5 text-xs font-medium text-[var(--destructive-foreground)]" data-on:click="@discobotCommand('/ui/commands/settings/cache/confirm', {method: 'POST'})">Clear cache</button>
				</div>
			</div>
		</div>
	}
}

templ settingsSupportInfoDialog() {
	<section class="absolute z-[110] w-full max-w-lg rounded-xl border border-[var(--border)] bg-[var(--background)] text-[var(--foreground)] shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="settings-support-title">
		<header class="border-b border-[var(--border)] p-5">
			<h3 id="settings-support-title" class="text-lg leading-none font-semibold">Support information</h3>
			<p class="mt-2 text-sm text-[var(--muted-foreground)]">Share this information when reporting issues.</p>
		</header>
		<div class="space-y-3 p-5 text-sm">
			<div class="rounded-md border border-[var(--border)] bg-[var(--muted)] p-3">
				<p class="font-medium">Discobot</p>
				<p class="text-[var(--muted-foreground)]">Server-rendered UI preview</p>
			</div>
			<div class="rounded-md border border-[var(--border)] bg-[var(--muted)] p-3">
				<p class="font-medium">Diagnostics</p>
				<p class="text-[var(--muted-foreground)]">Include recent session logs, workspace details, and provider configuration when contacting support.</p>
			</div>
		</div>
		<footer class="flex justify-end border-t border-[var(--border)] p-5">
			<button type="button" class="rounded-md bg-[var(--primary)] px-4 py-2 text-sm font-medium text-[var(--primary-foreground)]" data-on:click="@discobotCommand('/ui/commands/settings/support/close', {method: 'POST'})">Done</button>
		</footer>
	</section>
}

templ settingsClearCacheDialog() {
	<section class="absolute z-[110] w-full max-w-md rounded-xl border border-[var(--border)] bg-[var(--background)] text-[var(--foreground)] shadow-2xl" role="alertdialog" aria-modal="true" aria-labelledby="settings-clear-cache-title" aria-describedby="settings-clear-cache-description">
		<header class="border-b border-[var(--border)] p-5">
			<h3 id="settings-clear-cache-title" class="text-lg leading-none font-semibold">Clear project cache?</h3>
			<p id="settings-clear-cache-description" class="mt-2 text-sm text-[var(--muted-foreground)]">This deletes the Docker cache volume for this project and removes unknown containers currently attached to it. No other named volumes will be deleted.</p>
		</header>
		<footer class="flex justify-end gap-2 p-5">
			<button type="button" class="rounded-md border border-[var(--border)] px-4 py-2 text-sm hover:bg-[var(--tree-hover)]" data-on:click="@discobotCommand('/ui/commands/settings/cache/cancel', {method: 'POST'})">Cancel</button>
			<button type="button" class="rounded-md bg-[var(--destructive)] px-4 py-2 text-sm font-medium text-[var(--destructive-foreground)]" data-on:click="@discobotCommand('/ui/commands/settings/cache/clear', {method: 'POST'})">Clear cache</button>
		</footer>
	</section>
}

templ settingsCredentialsTab() {
	@settingsCard("API Credentials", "Create, update, or remove credentials for Anthropic, OpenAI, Tavily, and GitHub.") {
		<div class="space-y-3 p-4">
			@settingsCredentialRow("Anthropic", "ANTHROPIC_API_KEY", true)
			@settingsCredentialRow("OpenAI", "OPENAI_API_KEY", true)
			@settingsCredentialRow("Tavily", "TAVILY_API_KEY", false)
			@settingsCredentialRow("GitHub", "GITHUB_TOKEN", false)
		</div>
	}
}

templ settingsCard(title string, description string) {
	<section class="rounded-xl border border-[var(--border)] bg-[var(--card)] text-[var(--card-foreground)] shadow-sm">
		<header class="flex items-start justify-between gap-4 border-b border-[var(--border)] p-4">
			<div class="space-y-1">
				<h3 class="text-sm font-medium">{ title }</h3>
				<p class="text-sm text-[var(--muted-foreground)]">{ description }</p>
			</div>
		</header>
		<div class="rounded-b-xl border-[var(--border)]">
			<div class="m-4 rounded-md border border-[var(--border)]">
				{ children... }
			</div>
		</div>
	</section>
}

templ settingsItem(title string, description string) {
	<div class="flex min-h-14 items-center justify-between gap-4 p-4">
		<div class="space-y-1">
			<p class="text-sm font-medium">{ title }</p>
			<p class="text-sm text-[var(--muted-foreground)]">{ description }</p>
		</div>
		<div class="ml-auto shrink-0">
			{ children... }
		</div>
	</div>
}

templ settingsSwitchItem(title string, description string, checked bool) {
	@settingsItem(title, description) {
		@settingsSwitch(checked)
	}
}

templ settingsSwitch(checked bool) {
	<button type="button" class={ settingsSwitchClass(checked) } aria-pressed={ helpers.BoolString(checked) }>
		<span class={ settingsSwitchThumbClass(checked) }></span>
	</button>
}

templ settingsSeparator() {
	<div class="h-px bg-[var(--border)]"></div>
}

templ settingsProviderRow(name string, description string, status string) {
	<div class="flex items-center justify-between gap-3 rounded-md border border-[var(--border)] bg-[var(--background)] p-3">
		<div class="space-y-1">
			<p class="text-sm font-medium">{ name }</p>
			<p class="text-sm text-[var(--muted-foreground)]">{ description }</p>
		</div>
		<span class="rounded-full border border-[var(--border)] px-2 py-1 text-xs text-[var(--muted-foreground)]">{ status }</span>
	</div>
}

templ settingsCredentialRow(provider string, key string, configured bool) {
	<div class="flex items-center justify-between gap-3 rounded-md border border-[var(--border)] bg-[var(--background)] p-3">
		<div class="space-y-1">
			<p class="text-sm font-medium">{ provider }</p>
			<p class="font-mono text-xs text-[var(--muted-foreground)]">{ key }</p>
		</div>
		<div class="flex items-center gap-2">
			<span class={ settingsCredentialStatusClass(configured) }>{ settingsCredentialStatus(configured) }</span>
			<button type="button" class="rounded-md border border-[var(--border)] px-3 py-1.5 text-xs hover:bg-[var(--tree-hover)]">{ settingsCredentialAction(configured) }</button>
		</div>
	</div>
}

func settingsTabButtonClass(active state.SettingsTab, tab state.SettingsTab) string {
	class := "rounded-md px-3 py-2 text-center text-sm transition hover:text-[var(--foreground)]"
	if active == tab {
		return class + " bg-[var(--background)] text-[var(--foreground)] shadow-sm"
	}
	return class + " text-[var(--muted-foreground)]"
}

func settingsTabCommand(tab state.SettingsTab) string {
	return "@discobotCommand(" + strconv.Quote("/ui/commands/settings/tabs/"+string(tab)) + ", {method: 'POST'})"
}

func settingsSwitchClass(checked bool) string {
	class := "relative inline-flex h-6 w-11 rounded-full border border-transparent transition"
	if checked {
		return class + " bg-[var(--primary)]"
	}
	return class + " bg-[var(--muted)]"
}

func settingsSwitchThumbClass(checked bool) string {
	class := "absolute top-0.5 h-5 w-5 rounded-full bg-[var(--background)] shadow transition"
	if checked {
		return class + " left-5"
	}
	return class + " left-0.5"
}

func settingsCredentialStatus(configured bool) string {
	if configured {
		return "Configured"
	}
	return "Missing"
}

func settingsCredentialStatusClass(configured bool) string {
	class := "rounded-full px-2 py-1 text-xs"
	if configured {
		return class + " bg-[var(--diff-add-line)] text-[var(--foreground)]"
	}
	return class + " bg-[var(--muted)] text-[var(--muted-foreground)]"
}

func settingsCredentialAction(configured bool) string {
	if configured {
		return "Update"
	}
	return "Add"
}
