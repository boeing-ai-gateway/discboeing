# Agent watcher local overrides
# Copy to .env and edit as needed (this file is checked in; .env is gitignored)

# Docker build target for the sandbox image.
# runtime-shell  - no graphical tools (default, faster builds)
# runtime        - full graphical desktop (X11, VNC, Chromium)
#SANDBOX_TARGET=runtime-shell

# Optional remote repository for dev sandbox images used by remote providers.
# If unset, the watcher derives this from server/.env SANDBOX_IMAGE_REMOTE when
# that value exists. The watcher tags images as <repo>:<image-id> and pushes
# them, then writes SANDBOX_IMAGE_REMOTE=<repo>:<image-id> to server/.env.
#SANDBOX_IMAGE_REMOTE_REPOSITORY=ghcr.io/example/discboeing
