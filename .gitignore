# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/.idea
/.zed/*

# dependencies
/node_modules
/ui/node_modules

# next.js
/.next/
/.next-tauri/
/out/

# production
/build
/dist
/.electron-dist
/ui/build
/ui/.svelte-kit

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (but allow example files)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# server workspace storage (cloned repos, etc.)
/server/workspaces

# Claude Code settings (may contain API keys)
.claude/settings.json
.claude/settings.local.json

# Bundled guest runtime artifacts (rootfs image, kernel)
/src-tauri/resources/*
!/src-tauri/resources/
!/src-tauri/resources/wsl/
/src-tauri/resources/wsl/*
!/src-tauri/resources/wsl/.gitkeep

# Binaries
proxy/discobot-proxy
server/server
agent/agent
/meta/build/

# SSH Key
server/ssh_host_key

# Python
.venv/
__pycache__/

# Test DB script
/test.db.sql

# Generated OpenAI overlay probe artifacts
/modelsdev/model-overlay.openai-probed*.json

# Generated Anthropic overlay probe artifacts
/modelsdev/model-overlay.anthropic-probed*.json

# misc
