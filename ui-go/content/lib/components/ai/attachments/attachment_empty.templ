package attachments

import ahtempl "github.com/a-h/templ"
import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"

templ AttachmentEmpty(className string, children ahtempl.Component) {
	<div class={ classnames.CN("flex items-center justify-center p-4 text-muted-foreground text-sm", className) }>
		if children != nil {
			@children
		} else {
			No attachments
		}
	</div>
}
