package codeblock

import ahtempl "github.com/a-h/templ"
import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"

templ CodeBlockContainer(language string, className string, children ahtempl.Component) {
	<div class={ classnames.CN("group relative w-full overflow-hidden rounded-md border bg-background text-foreground", className) } data-language={ language } style="content-visibility: auto; contain-intrinsic-size: auto 200px;">
		if children != nil {
			@children
		}
	</div>
}
