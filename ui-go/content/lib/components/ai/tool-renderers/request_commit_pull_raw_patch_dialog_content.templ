package toolrenderers

import (
	"strings"

	codeblock "github.com/obot-platform/discobot/ui-go/content/lib/components/ai/code-block"
	dialog "github.com/obot-platform/discobot/ui-go/content/lib/components/ui/dialog"
)

templ RequestCommitPullRawPatchDialogContent(rawPatch string) {
	<div class="space-y-4">
		@dialog.DialogHeader("", requestCommitPullRawPatchDialogHeader())
		<div class="max-h-[68vh] overflow-auto">
			if strings.TrimSpace(rawPatch) != "" {
				@codeblock.CodeBlock(codeblock.View{Code: rawPatch, Language: "diff", ShowLineNumbers: true}, "pr-1", requestCommitPullRawPatchHeader(rawPatch))
			} else {
				<div class="text-muted-foreground text-sm">No raw patch is available.</div>
			}
		</div>
	</div>
}

templ requestCommitPullRawPatchDialogHeader() {
	@dialog.DialogTitle("", requestCommitPullRawPatchDialogTitle())
	@dialog.DialogDescription("", requestCommitPullRawPatchDialogDescription())
}

templ requestCommitPullRawPatchDialogTitle() {
	Raw patch
}

templ requestCommitPullRawPatchDialogDescription() {
	Review the raw replay bundle text that will be applied.
}

templ requestCommitPullRawPatchHeader(rawPatch string) {
	@codeblock.CodeBlockHeader("", requestCommitPullRawPatchHeaderInner(rawPatch))
}

templ requestCommitPullRawPatchHeaderInner(rawPatch string) {
	@codeblock.CodeBlockTitle("", requestCommitPullRawPatchTitle())
	@codeblock.CodeBlockActions("", codeblock.CodeBlockCopyButtonWithLabel(rawPatch, "", "Copy raw patch", requestCommitPullRawPatchCopyLabel()))
}

templ requestCommitPullRawPatchTitle() {
	diff
}

templ requestCommitPullRawPatchCopyLabel() {
	<span class="sr-only">Copy raw patch</span>
}
