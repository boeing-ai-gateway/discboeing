package message

import "fmt"
import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"

templ MessageBranchPage(branch BranchView, className string) {
	<div class={ classnames.CN("border-none bg-transparent text-muted-foreground shadow-none px-2 text-sm", className) }>
		{ fmt.Sprintf("%d of %d", branchPage(branch), branchTotal(branch)) }
	</div>
}
