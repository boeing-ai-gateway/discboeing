package message

import ahtempl "github.com/a-h/templ"
import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"

templ MessageBranchContent(branch BranchView, contentBranch int, className string, children ahtempl.Component) {
	if contentBranch == branch.Current {
		<div class={ classnames.CN("grid gap-2 overflow-hidden [&>div]:pb-0", className) }>
			if children != nil {
				@children
			}
		</div>
	}
}
