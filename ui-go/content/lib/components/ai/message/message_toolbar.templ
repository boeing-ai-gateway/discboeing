package message

import ahtempl "github.com/a-h/templ"
import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"

templ MessageToolbar(className string, children ahtempl.Component) {
	<div class={ classnames.CN("mt-4 flex w-full items-center justify-between gap-4", className) }>
		if children != nil {
			@children
		}
	</div>
}
