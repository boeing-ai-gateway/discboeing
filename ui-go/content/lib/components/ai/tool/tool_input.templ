package tool

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
templ ToolInput(inputJSON string, className string) {
	<div class={ classnames.CN("space-y-2 overflow-hidden p-4", className) }>
		<h4 class="font-medium text-muted-foreground text-xs uppercase tracking-wide">Parameters</h4>
		<div class="rounded-md bg-muted/50">
			<pre class="overflow-x-auto p-3 font-mono text-xs text-foreground"><code>{ inputJSON }</code></pre>
		</div>
	</div>
}
