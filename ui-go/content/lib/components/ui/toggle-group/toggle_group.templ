package togglegroup

import ahtempl "github.com/a-h/templ"
import "strconv"

templ ToggleGroup(value string, variant string, size string, spacing int, className string, children ahtempl.Component) {
	<div data-slot="toggle-group" data-value={ value } data-variant={ variant } data-size={ size } data-spacing={ strconv.Itoa(spacing) } style={ "--gap: " + strconv.Itoa(spacing) } class={ groupClass(className) }>
		if children != nil {
			@children
		}
	</div>
}
