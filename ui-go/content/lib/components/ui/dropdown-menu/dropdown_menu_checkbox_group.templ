package dropdownmenu

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ DropdownMenuCheckboxGroup(value string, className string, children ahtempl.Component) {
	<div data-slot="dropdown-menu-checkbox-group" data-value={ value } role="group" class={ classnames.CN(className) }>
		if children != nil {
			@children
		}
	</div>
}
