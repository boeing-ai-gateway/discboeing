package dropdownmenu

import ahtempl "github.com/a-h/templ"

templ DropdownMenuGroupHeading(inset bool, className string, children ahtempl.Component) {
	<div data-slot="dropdown-menu-group-heading" data-inset={ boolString(inset) } class={ labelClass(className) }>
		if children != nil {
			@children
		}
	</div>
}
