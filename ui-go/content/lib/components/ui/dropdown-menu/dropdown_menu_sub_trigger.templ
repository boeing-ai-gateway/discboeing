package dropdownmenu

import lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"
import ahtempl "github.com/a-h/templ"

templ DropdownMenuSubTrigger(open bool, inset bool, disabled bool, className string, children ahtempl.Component) {
	<div data-slot="dropdown-menu-sub-trigger" data-state={ state(open) } data-inset={ boolString(inset) } data-disabled?={ disabled } class={ subTriggerClass(className) }>
		if children != nil {
			@children
		}
		@lucide.ChevronRight(ahtempl.Attributes{"class": "ms-auto size-4"})
	</div>
}
