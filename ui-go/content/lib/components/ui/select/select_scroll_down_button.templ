package selectui

import lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"
import ahtempl "github.com/a-h/templ"

templ SelectScrollDownButton(className string) {
	<div data-slot="select-scroll-down-button" class={ scrollButtonClass(className) }>
		@lucide.ChevronDown(ahtempl.Attributes{"class": "size-4"})
	</div>
}
