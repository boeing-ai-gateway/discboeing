package collapsible

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ CollapsibleTrigger(open bool, disabled bool, className string, children ahtempl.Component) {
	<button type="button" data-slot="collapsible-trigger" data-state={ collapsibleState(open) } aria-expanded={ open } class={ classnames.CN(className) } disabled?={ disabled }>
		if children != nil {
			@children
		}
	</button>
}
