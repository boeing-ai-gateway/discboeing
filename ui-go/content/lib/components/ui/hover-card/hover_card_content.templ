package hovercard

import "fmt"
import ahtempl "github.com/a-h/templ"

templ HoverCardContent(open bool, side string, align string, sideOffset int, className string, children ahtempl.Component) {
	<div data-slot="hover-card-portal">
		<div data-slot="hover-card-content" data-state={ state(open) } data-side={ side } data-align={ align } data-side-offset={ fmt.Sprint(sideOffset) } class={ contentClass(className) }>
			if children != nil {
				@children
			}
		</div>
	</div>
}
