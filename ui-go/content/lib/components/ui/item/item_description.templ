package item

import ahtempl "github.com/a-h/templ"

templ ItemDescription(className string, children ahtempl.Component) {
	<p data-slot="item-description" class={ joinClass("text-muted-foreground line-clamp-2 text-sm leading-normal font-normal text-balance [&>a:hover]:text-primary [&>a]:underline [&>a]:underline-offset-4", className) }>
		if children != nil {
			@children
		}
	</p>
}
