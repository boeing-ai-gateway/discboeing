package tabs

import ahtempl "github.com/a-h/templ"

templ TabsTrigger(value string, active bool, disabled bool, className string, children ahtempl.Component) {
	<button type="button" role="tab" data-slot="tabs-trigger" data-value={ value } data-state={ state(active) } aria-selected={ active } class={ triggerClass(className) } disabled?={ disabled }>
		if children != nil {
			@children
		}
	</button>
}
