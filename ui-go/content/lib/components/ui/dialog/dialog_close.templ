package dialog

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ DialogClose(className string, children ahtempl.Component) {
	<button type="button" data-slot="dialog-close" class={ classnames.CN(className) }>
		if children != nil {
			@children
		}
	</button>
}
