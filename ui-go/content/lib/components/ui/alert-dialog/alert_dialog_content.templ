package alertdialog

import ahtempl "github.com/a-h/templ"

templ AlertDialogContent(className string, children ahtempl.Component) {
	@AlertDialogPortal(AlertDialogContentShell(className, children))
}

templ AlertDialogContentShell(className string, children ahtempl.Component) {
	@AlertDialogOverlay("")
	<div data-slot="alert-dialog-content" role="alertdialog" aria-modal="true" class={ contentClass(className) }>
		if children != nil {
			@children
		}
	</div>
}
