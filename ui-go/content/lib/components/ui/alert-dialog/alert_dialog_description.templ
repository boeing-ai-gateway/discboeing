package alertdialog

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ AlertDialogDescription(className string, children ahtempl.Component) {
	<div data-slot="alert-dialog-description" class={ classnames.CN("text-muted-foreground text-sm", className) }>
		if children != nil {
			@children
		}
	</div>
}
