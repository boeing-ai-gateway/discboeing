package alertdialog

import ahtempl "github.com/a-h/templ"

templ AlertDialogFooter(className string, children ahtempl.Component) {
	<div data-slot="alert-dialog-footer" class={ joinClass("flex flex-col-reverse gap-2 sm:flex-row sm:justify-end", className) }>
		if children != nil {
			@children
		}
	</div>
}
