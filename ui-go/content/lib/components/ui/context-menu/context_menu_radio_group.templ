package contextmenu

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ ContextMenuRadioGroup(value string, className string, children ahtempl.Component) {
	<div data-slot="context-menu-radio-group" data-value={ value } role="radiogroup" class={ classnames.CN(className) }>
		if children != nil {
			@children
		}
	</div>
}
