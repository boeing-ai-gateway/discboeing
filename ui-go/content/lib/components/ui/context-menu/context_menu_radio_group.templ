package contextmenu

import ahtempl "github.com/a-h/templ"

templ ContextMenuRadioGroup(value string, className string, children ahtempl.Component) {
	<div data-slot="context-menu-radio-group" data-value={ value } role="radiogroup" class={ joinClass(className) }>
		if children != nil {
			@children
		}
	</div>
}
