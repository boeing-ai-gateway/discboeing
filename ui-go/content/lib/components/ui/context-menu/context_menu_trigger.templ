package contextmenu

import "github.com/obot-platform/discobot/ui-go/content/lib/classnames"
import ahtempl "github.com/a-h/templ"

templ ContextMenuTrigger(className string, children ahtempl.Component) {
	<div data-slot="context-menu-trigger" class={ classnames.CN(className) }>
		if children != nil {
			@children
		}
	</div>
}
