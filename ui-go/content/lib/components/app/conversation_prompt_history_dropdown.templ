package app

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationPromptHistoryDropdown(snapshot viewmodel.ConversationPromptHistorySnapshot) {
	if snapshot.Open && hasPromptHistoryItems(snapshot) {
		<div class="absolute bottom-full left-0 right-0 z-50 mb-1 flex max-h-96 flex-col overflow-hidden rounded-lg border border-border bg-popover shadow-lg" data-conversation-prompt-history>
			<div class="sticky top-0 z-10 flex items-center gap-2 border-b border-border bg-popover px-3 py-2">
				@lucide.History(ahtempl.Attributes{"class": "size-4 text-muted-foreground"})
				<span class="text-xs font-medium text-muted-foreground">Prompt history</span>
				<span class="ml-auto flex items-center gap-1 text-xs text-muted-foreground">
					@lucide.ChevronUp(ahtempl.Attributes{"class": "size-3"})
					/
					@lucide.ChevronDown(ahtempl.Attributes{"class": "size-3"})
					navigate
				</span>
			</div>
			<div class="overflow-y-auto py-1">
				if len(snapshot.PinnedPrompts) > 0 {
					<div class="px-3 py-1.5 text-xs font-medium text-muted-foreground">Pinned</div>
					for index, prompt := range snapshot.PinnedPrompts {
						<div class={ promptHistoryItemClass(promptHistoryPinnedSelected(snapshot, index)) } data-pinned-index={ strconv.Itoa(index) }>
							<button type="button" class="flex-1 text-left text-sm" aria-label={ "Use pinned prompt: " + prompt } disabled>
								<span class="line-clamp-2 break-words">{ prompt }</span>
							</button>
							<button type="button" class="shrink-0 opacity-0 transition-opacity group-hover:opacity-100" title="Unpin" aria-label={ "Unpin prompt: " + prompt } disabled>
								@lucide.Pin(ahtempl.Attributes{"class": "size-3.5 fill-current text-muted-foreground hover:text-foreground"})
							</button>
						</div>
					}
				}
				if len(snapshot.RecentPrompts) > 0 {
					<div class={ "px-3 py-1.5 text-xs font-medium text-muted-foreground " + promptHistoryRecentHeaderClass(snapshot) }>
						Recent
					</div>
					for index, prompt := range snapshot.RecentPrompts {
						<div class={ promptHistoryItemClass(promptHistoryRecentSelected(snapshot, index)) } data-history-index={ strconv.Itoa(index) }>
							<button type="button" class="flex-1 text-left text-sm" aria-label={ "Use recent prompt: " + prompt } disabled>
								<span class="line-clamp-2 break-words">{ prompt }</span>
							</button>
							<div class="flex shrink-0 items-center gap-1 opacity-0 transition-opacity group-hover:opacity-100">
								<button type="button" title="Pin" aria-label={ "Pin prompt: " + prompt } disabled>
									@lucide.Pin(ahtempl.Attributes{"class": "size-3.5 text-muted-foreground hover:text-foreground"})
								</button>
								<button type="button" title="Delete from history" aria-label={ "Delete prompt from history: " + prompt } disabled>
									@lucide.Trash2(ahtempl.Attributes{"class": "size-3.5 text-muted-foreground hover:text-foreground"})
								</button>
							</div>
						</div>
					}
				}
			</div>
		</div>
	}
}
