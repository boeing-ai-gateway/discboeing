package app

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	uidialog "github.com/obot-platform/discobot/ui-go/content/lib/components/ui/dialog"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ SettingsDialog(snapshot viewmodel.SettingsDialogSnapshot) {
	@SupportInfoDialog(snapshot.SupportInfo)
	@uidialog.Dialog(snapshot.Open) {
		@uidialog.DialogContentAttrs(snapshot.Open, "top-10 max-h-[90vh] w-[calc(100vw-2rem)] max-w-none translate-y-0 overflow-y-auto shadow-xl sm:!max-w-4xl", "", false, ahtempl.Attributes{
			"data-settings-dialog": "",
			"data-settings-active-tab": settingsActiveTab(snapshot),
			"data-dialog-dismiss-url": settingsCloseURL(),
			"aria-labelledby": "settings-dialog-title",
			"aria-describedby": "settings-dialog-description",
		}) {
				<div>
					<h2 id="settings-dialog-title" class="text-lg font-semibold">Settings</h2>
					<p id="settings-dialog-description" class="mt-1 text-sm text-muted-foreground">
						Configure appearance, chat defaults, providers,
						if snapshot.ShowUpdateTab {
							<span> updates, and support tools.</span>
						} else {
							<span> and support tools.</span>
						}
					</p>
				</div>
				<div class="mt-4">
					<div class={ "grid w-full rounded-md bg-muted p-1 " + settingsTabsGridClass(snapshot.ShowUpdateTab) } role="tablist" aria-label="Settings sections">
						@settingsTabButton(snapshot, "appearance", "Appearance")
						@settingsTabButton(snapshot, "chat", "Chat")
						@settingsTabButton(snapshot, "providers", "Providers")
						if snapshot.ShowUpdateTab {
							<button
								type="button"
								id={ settingsTabID("update") }
								class={ settingsTabClass(settingsTabActive(snapshot, "update")) }
								role="tab"
								aria-selected={ strconv.FormatBool(settingsTabActive(snapshot, "update")) }
								aria-controls={ settingsPanelID("update") }
								data-settings-tab="update"
								data-on:click={ settingsTabCommand("update") }
							>
								<span class="relative inline-flex items-center px-2">
									Update
									if snapshot.ShowUpdateBadge {
										<span class="absolute -right-1 top-0 h-2 w-2 rounded-full bg-blue-500"></span>
									}
								</span>
							</button>
						}
						@settingsTabButton(snapshot, "credentials", "Credentials")
					</div>
					<div class="mt-3 min-h-[28rem]">
						<div
							id={ settingsPanelID("appearance") }
							class={ settingsPanelClass(snapshot, "appearance") }
							role="tabpanel"
							aria-labelledby={ settingsTabID("appearance") }
							data-settings-panel="appearance"
							data-signals={ settingsThemeSignals(snapshot) }
							data-init={ settingsThemeInitExpression() }
							data-effect="window.uiGoThemeApply($_themeMode, $_themeResolved === 'dark' ? $_themeDarkColorScheme : $_themeLightColorScheme)"
							data-on:ui-go-theme-system-change__window={ settingsThemeSystemChangeExpression() }
						>
							@settingsCard("Appearance", "Mode and color theme preferences.") {
								<div class="flex items-center justify-between gap-4 border-b border-border py-3 last:border-b-0">
									<div class="min-w-0">
										<div class="text-sm font-medium">Mode</div>
										<div class="mt-1 text-sm text-muted-foreground">Resolved mode: <span data-settings-resolved-theme data-text="$_themeResolved">{ snapshot.ResolvedTheme }</span></div>
									</div>
									<div class="ml-auto shrink-0">
										<div class="inline-flex rounded-full border border-border bg-muted p-1" role="radiogroup" aria-label="Theme mode">
											for _, mode := range []string{"light", "dark", "system"} {
												<button
													type="button"
													class={ settingsThemeModeButtonClass() }
													role="radio"
													aria-checked={ strconv.FormatBool(snapshot.Theme == mode) }
													data-settings-theme-mode={ mode }
													data-attr:aria-checked={ "$_themeMode === " + strconv.Quote(mode) }
													data-class={ settingsThemeModeButtonClassExpression(mode) }
													data-on:click={ settingsThemeModeClickExpression(mode) }
												>{ mode }</button>
											}
										</div>
									</div>
								</div>
								<div class="flex items-center justify-between gap-4 border-b border-border py-3 last:border-b-0">
									<div class="min-w-0">
										<div class="text-sm font-medium">Theme</div>
										<div class="mt-1 text-sm text-muted-foreground">Current palette: <span data-settings-active-theme-name data-text="window.uiGoThemeColorSchemeName($_themeResolved === 'dark' ? $_themeDarkColorScheme : $_themeLightColorScheme)">{ snapshot.ActiveThemeName }</span></div>
									</div>
									<div class="ml-auto shrink-0">
										<label class="sr-only" for="settings-theme-light">Light theme</label>
										<select id="settings-theme-light" class={ settingsThemeSelectClass() } data-settings-color-scheme="light" data-bind:_theme-light-color-scheme data-class={ settingsThemeSelectClassExpression("light") } data-attr:hidden="$_themeResolved !== 'light'" data-on:change={ settingsThemeSelectChangeExpression("light") }>
											for _, theme := range snapshot.AvailableThemes {
												if theme.Mode == "light" || theme.Mode == "system" {
													<option
														value={ theme.ID }
														selected?={ theme.ID == snapshot.ColorScheme }
														data-settings-theme-option-mode={ theme.Mode }
													>{ theme.Name }</option>
												}
											}
										</select>
										<label class="sr-only" for="settings-theme-dark">Dark theme</label>
										<select id="settings-theme-dark" class={ settingsThemeSelectClass() } data-settings-color-scheme="dark" data-bind:_theme-dark-color-scheme data-class={ settingsThemeSelectClassExpression("dark") } data-attr:hidden="$_themeResolved !== 'dark'" data-on:change={ settingsThemeSelectChangeExpression("dark") }>
											for _, theme := range snapshot.AvailableThemes {
												if theme.Mode == "dark" || theme.Mode == "system" {
													<option
														value={ theme.ID }
														selected?={ theme.ID == snapshot.ColorScheme }
														data-settings-theme-option-mode={ theme.Mode }
													>{ theme.Name }</option>
												}
											}
										</select>
									</div>
								</div>
								@settingsRow("Recent list size", "Choose how many recent threads appear in the sidebar.") {
									<div class="inline-flex rounded-full border border-border bg-muted p-1" role="radiogroup" aria-label="Recent list size">
										for _, limit := range []int{1, 3, 5, 10} {
											<button type="button" class={ settingsPillClass(snapshot.RecentThreadsLimit == limit) } role="radio" aria-checked={ strconv.FormatBool(snapshot.RecentThreadsLimit == limit) } data-settings-recent-limit={ strconv.Itoa(limit) } data-on:click={ settingsRecentLimitCommand(limit) }>
												if limit == 1 {
													<span>Off</span>
												} else {
													<span>{ strconv.Itoa(limit) }</span>
												}
											</button>
										}
									</div>
								}
								@settingsSwitchRow("Show refresh button", "Display a refresh button in the header bar.", snapshot.ShowRefreshButton)
								@settingsSwitchRow("Show editor button", "Display the embedded editor entry point in the session toolbar. Disabled by default.", snapshot.ShowEditorButton)
							}
						</div>
						<div id={ settingsPanelID("chat") } class={ settingsPanelClass(snapshot, "chat") } role="tabpanel" aria-labelledby={ settingsTabID("chat") } data-settings-panel="chat">
							@settingsCard("Chat", "Conversation defaults for new prompts.") {
								@settingsRow("Default model", "Set a preferred model or keep auto-select.") {
									<label class="sr-only" for="settings-default-model">Default model</label>
									<select id="settings-default-model" class="h-9 w-56 rounded-md border border-input bg-background px-3 text-sm" disabled>
										<option value="__auto__" selected?={ snapshot.DefaultModel == "" }>Auto-select</option>
										for _, provider := range settingsModelProviders(snapshot.Models) {
											<optgroup label={ provider }>
												for _, model := range snapshot.Models {
													if model.Provider == provider || (model.Provider == "" && provider == "Other") {
														<option value={ model.ID } selected?={ model.ID == snapshot.DefaultModel }>{ model.Name }</option>
													}
												}
											</optgroup>
										}
									</select>
								}
								@settingsSwitchRow("Full width conversation", "Expand messages and composer to use full space.", snapshot.ChatWidthMode == "full")
								@settingsSwitchRow("Auto-scroll", "Automatically scroll to the bottom while the agent is streaming a response.", snapshot.AutoScrollOnStream)
							}
						</div>
						<div id={ settingsPanelID("providers") } class={ settingsPanelClass(snapshot, "providers") } role="tabpanel" aria-labelledby={ settingsTabID("providers") } data-settings-panel="providers">
							@settingsCard("Sandbox Providers", "Configure sandbox provider instances and credential references.") {
								@SandboxProvidersManager(snapshot.SandboxProviders)
							}
						</div>
						if snapshot.ShowUpdateTab {
							<div id={ settingsPanelID("update") } class={ settingsPanelClass(snapshot, "update") } role="tabpanel" aria-labelledby={ settingsTabID("update") } data-settings-panel="update" data-update-status={ snapshot.Update.Status }>
								@settingsCard("Update", "Check, download, and install app updates.") {
									<div class="space-y-3">
										<div class="flex justify-end">
											<button type="button" class="inline-flex h-7 items-center gap-1.5 rounded-md px-2 text-xs text-muted-foreground hover:bg-accent" disabled>
												@lucide.RefreshCw(ahtempl.Attributes{"class": settingsUpdateCheckIconClass(snapshot.Update)})
												Check
											</button>
										</div>
										if snapshot.Update.CanTrackPrereleases {
											@settingsSwitchRow("Track pre-releases", "Use the latest GitHub pre-release channel instead of stable releases.", snapshot.Update.TrackPrereleases)
										}
										<div class="rounded-md border border-border bg-background p-3 text-sm text-muted-foreground">
											{ settingsUpdateMessage(snapshot.Update) }
											if snapshot.Update.Status == "downloading" {
												<div class="mt-2 h-2 overflow-hidden rounded-full bg-muted" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow={ strconv.Itoa(settingsUpdateProgress(snapshot.Update)) }>
													<div class="h-full bg-primary" style={ "width: " + strconv.Itoa(settingsUpdateProgress(snapshot.Update)) + "%" }></div>
												</div>
											}
										</div>
										if snapshot.CanClearProjectCache {
											<div class="rounded-md border border-destructive/30 bg-destructive/5 p-3">
												<div class="flex items-start justify-between gap-3">
													<div class="space-y-1">
														<p class="text-sm font-medium">Project cache</p>
														<p class="text-sm text-muted-foreground">Delete the Docker cache volume for this project and unknown containers attached to it. No other named volumes are removed.</p>
														if snapshot.ClearProjectCacheError != "" {
															<p class="text-sm text-destructive">{ snapshot.ClearProjectCacheError }</p>
														} else if snapshot.ClearProjectCacheSuccess {
															<p class="text-sm text-foreground">Cache cleared. Sessions will restart when they are used again.</p>
														}
													</div>
													<button type="button" class="h-8 rounded-md bg-destructive px-3 text-xs font-medium text-destructive-foreground opacity-60" disabled>Clear cache</button>
												</div>
											</div>
										}
									</div>
								}
							</div>
						}
						<div id={ settingsPanelID("credentials") } class={ settingsPanelClass(snapshot, "credentials") } role="tabpanel" aria-labelledby={ settingsTabID("credentials") } data-settings-panel="credentials">
							@settingsCard("API Credentials", "Create, update, or remove credentials for Anthropic, OpenAI, Tavily, and GitHub.") {
								@CredentialsManager(snapshot.Credentials)
							}
						</div>
					</div>
				</div>
				<div class="mt-3 flex w-full items-center justify-between gap-2">
					<button type="button" class="inline-flex size-8 items-center justify-center rounded-md border border-input text-muted-foreground hover:bg-accent" title="Support information" aria-label="Support information" data-on:click={ settingsSupportOpenCommand() }>
						@lucide.Info(ahtempl.Attributes{"class": "size-4"})
					</button>
					<button type="button" class="h-9 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90" data-on:click={ settingsCloseCommand() }>Done</button>
				</div>
		}
	}
}

templ settingsTabButton(snapshot viewmodel.SettingsDialogSnapshot, tab string, label string) {
	<button
		type="button"
		id={ settingsTabID(tab) }
		class={ settingsTabClass(settingsTabActive(snapshot, tab)) }
		role="tab"
		aria-selected={ strconv.FormatBool(settingsTabActive(snapshot, tab)) }
		aria-controls={ settingsPanelID(tab) }
		data-settings-tab={ tab }
		data-on:click={ settingsTabCommand(tab) }
	>{ label }</button>
}

templ settingsCard(title string, description string) {
	<div class="rounded-lg border border-border bg-card py-4 text-card-foreground shadow-xs">
		<div class="border-b px-6 pb-4">
			<div class="text-sm font-semibold">{ title }</div>
			<div class="mt-1 text-sm text-muted-foreground">{ description }</div>
		</div>
		<div class="px-6 pt-4">
			{ children... }
		</div>
	</div>
}

templ settingsRow(title string, description string) {
	<div class="flex items-center justify-between gap-4 border-b border-border py-3 last:border-b-0">
		<div class="min-w-0">
			<div class="text-sm font-medium">{ title }</div>
			<div class="mt-1 text-sm text-muted-foreground">{ description }</div>
		</div>
		<div class="ml-auto shrink-0">
			{ children... }
		</div>
	</div>
}

templ settingsSwitchRow(title string, description string, checked bool) {
	@settingsRow(title, description) {
		<button type="button" class={ settingsSwitchClass(checked) } role="switch" aria-checked={ strconv.FormatBool(checked) } aria-label={ title } data-settings-switch={ settingsSwitchKey(title) } data-on:click={ settingsToggleCommand(settingsSwitchKey(title)) }>
			<span class={ settingsSwitchThumbClass(checked) }></span>
		</button>
	}
}
