package app

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/components/app/parts"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposer(snapshot viewmodel.ConversationComposerSnapshot) {
	<div class="shrink-0 bg-background p-0 md:p-3" data-conversation-composer>
		<div class="w-full md:mx-auto md:max-w-3xl">
			if !snapshot.IsPending {
				@parts.ConversationQueuePanel(snapshot.QueueExpanded, snapshot.PlanEntries)
				@parts.ConversationPromptQueuePanel(snapshot.PromptQueue)
				@ConversationHooksPanel(snapshot.HooksPanel)
			}
			@ConversationComposerSessionSetupStatus(snapshot.IsPending, snapshot.SetupStatus)
			if snapshot.IsPending {
				<div class="mb-2 flex w-full flex-col gap-2 px-1 md:hidden">
					@ConversationWorkspaceSelector(composerMobileWorkspaceSelector(snapshot.WorkspaceSelector))
				</div>
			}
			if snapshot.Error != "" {
				<div class="mb-2 text-sm text-destructive">{ snapshot.Error }</div>
			}
			if snapshot.DisabledMessage != "" {
				<div class="mb-2 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
					<span>{ snapshot.DisabledMessage }</span>
				</div>
			}
			<div class="relative">
				@parts.ConversationSlashCommandDropdown(snapshot.SlashCommands)
				@parts.ConversationFileMentionDropdown(snapshot.FileMentions)
				@ConversationPromptHistoryDropdown(snapshot.PromptHistory)
				<form data-on:submit__prevent="@post('/ui/commands/composer-submit')">
					<input type="hidden" name="run_after" value={ snapshot.ScheduledRunAfter }/>
					<div data-slot="input-group" role="group" class="group/input-group border-input dark:bg-input/30 relative flex w-full items-center rounded-t-md rounded-b-none border bg-background shadow-xs transition-[color,box-shadow] outline-none h-auto flex-col md:rounded-md">
						@parts.ConversationComposerAttachments(snapshot.Attachments)
						@parts.ConversationComposerTextarea(snapshot.Draft, composerSubmitDisabled(snapshot), len(snapshot.Attachments))
						<div role="group" data-slot="input-group-addon" data-align="block-end" class="text-muted-foreground flex h-auto cursor-text items-center py-1.5 text-sm font-medium select-none order-last w-full px-3 pb-3 justify-between gap-1">
							<div class="desktop-no-drag flex min-w-0 flex-1 flex-wrap items-center gap-1">
								@parts.ConversationComposerAttachmentButton(composerSubmitDisabled(snapshot))
								if !snapshot.IsPending {
									@ConversationCredentialsControl(snapshot.Credentials)
								}
								@parts.ConversationComposerModelControl(snapshot.ModelID, snapshot.Models)
								@parts.ConversationComposerReasoningControl(snapshot.ReasoningValue, snapshot.DefaultReasoning, snapshot.ReasoningLevels)
								@parts.ConversationComposerServiceTierControl(snapshot.ServiceTierValue, snapshot.ServiceTiers)
							</div>
							<div class="desktop-no-drag flex items-center justify-end gap-2">
								if snapshot.IsPending {
									<div class="hidden items-center gap-2 md:flex">
										@ConversationWorkspaceSelector(snapshot.WorkspaceSelector)
									</div>
								} else {
									@parts.ConversationComposerHooksControl(snapshot.HooksPanel)
								}
								<div class="relative" data-composer-schedule-control>
									<button type="button" class={ composerScheduleButtonClass(snapshot) } title={ composerScheduleTitle(snapshot) } aria-label={ composerScheduleTitle(snapshot) } aria-expanded={ strconv.FormatBool(snapshot.ScheduleOpen) } data-on:click={ composerScheduleCommand("toggle") } disabled?={ composerSubmitDisabled(snapshot) }>
										@lucide.Clock(ahtempl.Attributes{"class": "size-4"})
									</button>
									<div class={ composerSchedulePopoverClass(snapshot) } data-composer-schedule-popover>
										<div class="space-y-3" role="group" aria-labelledby="conversation-composer-schedule-heading" data-conversation-prompt-schedule-picker data-current-run-after={ snapshot.ScheduledRunAfter } data-schedule-disabled={ strconv.FormatBool(composerSubmitDisabled(snapshot)) }>
											<div>
												<div id="conversation-composer-schedule-heading" class="text-sm font-medium">Run later</div>
												<div class="text-xs text-muted-foreground">Pick when this prompt becomes eligible.</div>
											</div>
											<div class="grid grid-cols-2 gap-2">
												<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="15" data-on:click={ composerScheduleOffsetCommand(15) } disabled?={ composerSubmitDisabled(snapshot) }>15 min</button>
												<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="60" data-on:click={ composerScheduleOffsetCommand(60) } disabled?={ composerSubmitDisabled(snapshot) }>1 hour</button>
												<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="1440" data-on:click={ composerScheduleOffsetCommand(1440) } disabled?={ composerSubmitDisabled(snapshot) }>1 day</button>
												<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="pause" data-on:click={ composerScheduleCommand("pause") } disabled?={ composerSubmitDisabled(snapshot) }>Pause</button>
											</div>
											<div class="space-y-2">
												<div class="text-xs font-medium text-muted-foreground">Custom time</div>
												<input type="datetime-local" name="schedule_custom_run_after" value={ composerScheduleCustomValue(snapshot) } class="border-input bg-background selection:bg-primary dark:bg-input/30 selection:text-primary-foreground ring-offset-background placeholder:text-muted-foreground flex h-9 w-full min-w-0 rounded-md border px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive" data-schedule-custom-input disabled?={ composerSubmitDisabled(snapshot) }/>
												<div class="flex justify-between gap-2">
													<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="run-now" data-on:click={ composerScheduleCommand("run-now") } disabled?={ composerSubmitDisabled(snapshot) }>Run now</button>
													<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-6 px-2" data-schedule-action="save-custom" data-on:click={ composerScheduleCommand("save-custom") } disabled?={ composerSubmitDisabled(snapshot) }>Save</button>
												</div>
											</div>
										</div>
									</div>
								</div>
								@parts.ConversationComposerSubmitButton(snapshot.SubmitStatus, composerInputEmpty(snapshot), snapshot.IsPending, composerSubmitDisabled(snapshot))
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
}
