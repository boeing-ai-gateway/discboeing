package app

import (
	"github.com/obot-platform/discobot/ui-go/content/lib/components/app/parts"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposer(snapshot viewmodel.ConversationComposerSnapshot) {
	<div class="shrink-0 bg-background p-0 md:p-3" data-conversation-composer>
		<div class="w-full md:mx-auto md:max-w-3xl">
			if !snapshot.IsPending {
				@parts.ConversationQueuePanel(snapshot.QueueExpanded, snapshot.PlanEntries)
				@parts.ConversationPromptQueuePanel(snapshot.PromptQueue)
				@ConversationHooksPanel(snapshot.HooksPanel)
			}
			@ConversationComposerSessionSetupStatus(snapshot.IsPending, snapshot.SetupStatus)
			if snapshot.IsPending {
				<div class="mb-2 flex w-full flex-col gap-2 px-1 md:hidden">
					@ConversationWorkspaceSelector(composerMobileWorkspaceSelector(snapshot.WorkspaceSelector))
				</div>
			}
			if snapshot.Error != "" {
				<div class="mb-2 text-sm text-destructive">{ snapshot.Error }</div>
			}
			if snapshot.DisabledMessage != "" {
				<div class="mb-2 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
					<span>{ snapshot.DisabledMessage }</span>
				</div>
			}
			<div class="relative">
				@parts.ConversationSlashCommandDropdown(snapshot.SlashCommands)
				@parts.ConversationFileMentionDropdown(snapshot.FileMentions)
				@ConversationPromptHistoryDropdown(snapshot.PromptHistory)
				<form data-on:submit__prevent="@post('/ui/commands/composer-submit')">
					<input type="hidden" name="run_after" value={ snapshot.ScheduledRunAfter }/>
					<div data-slot="input-group" role="group" class="group/input-group border-input dark:bg-input/30 relative flex w-full items-center rounded-t-md rounded-b-none border bg-background shadow-xs transition-[color,box-shadow] outline-none h-auto flex-col md:rounded-md">
						@parts.ConversationComposerAttachments(snapshot.Attachments)
						@parts.ConversationComposerTextarea(snapshot.Draft, composerSubmitDisabled(snapshot), len(snapshot.Attachments))
						<div role="group" data-slot="input-group-addon" data-align="block-end" class="text-muted-foreground flex h-auto cursor-text items-center py-1.5 text-sm font-medium select-none order-last w-full px-3 pb-3 justify-between gap-1">
							<div class="desktop-no-drag flex min-w-0 flex-1 flex-wrap items-center gap-1">
								@parts.ConversationComposerAttachmentButton(composerSubmitDisabled(snapshot))
								if !snapshot.IsPending {
									@ConversationCredentialsControl(snapshot.Credentials)
								}
								@parts.ConversationComposerModelControl(snapshot.ModelID, snapshot.Models)
								@parts.ConversationComposerReasoningControl(snapshot.ReasoningValue, snapshot.DefaultReasoning, snapshot.ReasoningLevels)
								@parts.ConversationComposerServiceTierControl(snapshot.ServiceTierValue, snapshot.ServiceTiers)
							</div>
							<div class="desktop-no-drag flex items-center justify-end gap-2">
								if snapshot.IsPending {
									<div class="hidden items-center gap-2 md:flex">
										@ConversationWorkspaceSelector(snapshot.WorkspaceSelector)
									</div>
								} else {
									@parts.ConversationComposerHooksControl(snapshot.HooksPanel)
								}
								@parts.ConversationComposerScheduleControl(snapshot)
								@parts.ConversationComposerSubmitButton(snapshot.SubmitStatus, composerInputEmpty(snapshot), snapshot.IsPending, composerSubmitDisabled(snapshot))
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
}
