package parts

import (
	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerModelControl(value string, models []viewmodel.ModelOption) {
	<div class="relative inline-flex" data-composer-model-control data-composer-model-value={ value } data-composer-model-count={ composerModelCount(models) }>
		<button
			type="button"
			class="desktop-no-drag inline-flex h-6 max-w-[160px] items-center gap-1.5 rounded-md px-2 text-xs text-muted-foreground hover:bg-accent hover:text-accent-foreground"
			title={ composerModelTitle(value, models) }
			aria-label={ composerModelTitle(value, models) }
			aria-haspopup="menu"
			aria-controls="composer-model-menu"
			aria-expanded="false"
			disabled
		>
			if composerSelectedModelName(value, models) != "" {
				<span class="truncate">{ composerSelectedModelName(value, models) }</span>
			} else {
				@lucide.Brain(ahtempl.Attributes{"class": "size-3.5 shrink-0"})
			}
		</button>
		<div id="composer-model-menu" class="absolute bottom-full left-0 z-50 mb-2 hidden max-h-[24rem] w-80 overflow-y-auto rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md" role="menu" data-composer-model-menu>
			<div class="flex items-center justify-between rounded-sm px-2 py-1.5 text-sm" role="menuitemradio" aria-checked={ composerModelSelected(value, "") } data-composer-model-option="__default__">
				<span>Default model</span>
				if value == "" {
					@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
				}
			</div>
			if len(models) > 0 {
				<div class="-mx-1 my-1 h-px bg-border"></div>
			}
			for providerIndex, provider := range composerModelProviders(models) {
				if providerIndex > 0 {
					<div class="-mx-1 my-1 h-px bg-border"></div>
				}
				<div class="px-2 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground" role="presentation">{ provider }</div>
				for _, model := range models {
					if model.Provider == provider || (model.Provider == "" && provider == "Other") {
						<div class="flex items-center justify-between gap-3 rounded-sm px-2 py-1.5 text-sm" role="menuitemradio" aria-checked={ composerModelSelected(value, model.ID) } data-composer-model-option={ model.ID } data-composer-model-provider={ provider }>
							<div class="min-w-0 flex-1 pl-3">
								<div class="truncate font-medium">{ cleanComposerModelName(model.Name) }</div>
								if model.Description != "" {
									<div class="truncate text-xs text-muted-foreground">{ model.Description }</div>
								}
							</div>
							if value == model.ID {
								@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
							}
						</div>
					}
				}
			}
		</div>
	</div>
}
