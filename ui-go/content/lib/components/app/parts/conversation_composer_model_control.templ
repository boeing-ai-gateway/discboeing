package parts

import (
	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerModelControl(value string, models []viewmodel.ModelOption) {
	{{ dedupedModels := composerDedupedModels(models) }}
	<div class="relative inline-flex" data-composer-model-control data-composer-model-value={ value } data-composer-model-count={ composerModelCount(dedupedModels) } data-on:pointerdown__outside="discobot.composerControls.closeModel()" data-on:keydown__escape__window="discobot.composerControls.closeAll()">
		<button
			type="button"
			class="desktop-no-drag inline-flex h-6 max-w-[160px] items-center justify-center gap-1.5 rounded-md px-2 text-xs font-medium whitespace-nowrap transition-all outline-none hover:bg-accent hover:text-accent-foreground focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50"
			title={ composerModelTitle(value, dedupedModels) }
			aria-label={ composerModelTitle(value, dedupedModels) }
			aria-haspopup="menu"
			aria-controls="composer-model-menu"
			aria-expanded="false"
			data-composer-model-trigger
			data-on:click__prevent="discobot.composerControls.toggleModel(el)"
		>
			if composerSelectedModelName(value, dedupedModels) != "" {
				<span class="truncate">{ composerSelectedModelName(value, dedupedModels) }</span>
			} else {
				@lucide.Brain(ahtempl.Attributes{"class": "size-3.5 shrink-0"})
			}
		</button>
		<div id="composer-model-menu" class="absolute bottom-full left-0 z-50 mb-2 hidden max-h-[24rem] w-80 overflow-y-auto rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md outline-none" role="menu" data-composer-model-menu>
			<button type="button" class="relative flex w-full cursor-default items-center justify-between gap-2 rounded-sm px-2 py-1.5 text-left text-sm outline-hidden select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground" role="menuitemradio" aria-checked={ composerModelSelected(value, "") } data-composer-model-option="__default__" data-on:click={ composerModelOptionCommand("") }>
				<span>Default model</span>
				if value == "" {
					@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
				}
			</button>
			if len(dedupedModels) > 0 {
				<div class="-mx-1 my-1 h-px bg-border"></div>
			}
			for providerIndex, provider := range composerModelProviders(dedupedModels) {
				if providerIndex > 0 {
					<div class="-mx-1 my-1 h-px bg-border"></div>
				}
				<div class="px-2 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground" role="presentation">{ provider }</div>
				for _, model := range dedupedModels {
					if model.Provider == provider || (model.Provider == "" && provider == "Other") {
						<button type="button" class="relative flex w-full cursor-default items-center justify-between gap-3 rounded-sm px-2 py-1.5 text-left text-sm outline-hidden select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground" role="menuitemradio" aria-checked={ composerModelSelected(value, model.ID) } data-composer-model-option={ model.ID } data-composer-model-provider={ provider } data-on:click={ composerModelOptionCommand(model.ID) }>
							<div class="min-w-0 flex-1 pl-3">
								<div class="truncate font-medium">{ model.Name }</div>
								if model.Description != "" {
									<div class="truncate text-xs text-muted-foreground">{ model.Description }</div>
								}
							</div>
							if value == model.ID {
								@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
							}
						</button>
					}
				}
			}
		</div>
	</div>
}
