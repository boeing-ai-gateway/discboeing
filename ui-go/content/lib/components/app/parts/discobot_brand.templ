package parts

templ DiscobotBrand(className string, heightClass string, title string) {
	<img
		src="/branding-assets/discobot-brand-gradient.svg"
		alt={ discobotTitle(title, defaultDiscobotBrandTitle) }
		title={ discobotTitle(title, defaultDiscobotBrandTitle) }
		class={ brandImageClass(className, discobotBrandHeightClass(heightClass)) }
	/>
}
