package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationFileMentionDropdown(snapshot viewmodel.FileMentionDropdownSnapshot) {
	if fileMentionShouldRender(snapshot) {
		<div
			id="conversation-file-mention-dropdown"
			class="absolute bottom-full left-0 right-0 z-50 mb-1 flex max-h-64 flex-col overflow-hidden rounded-lg border border-border bg-popover shadow-lg"
			role="listbox"
			aria-label="File suggestions"
			aria-activedescendant={ fileMentionActiveID(snapshot) }
			data-file-mention-dropdown
			data-file-mention-open={ strconv.FormatBool(snapshot.Open) }
			data-file-mention-loading={ strconv.FormatBool(snapshot.Loading) }
			data-file-mention-query={ snapshot.Query }
			data-file-mention-count={ strconv.Itoa(len(snapshot.Suggestions)) }
			data-file-mention-selected-index={ strconv.Itoa(snapshot.SelectedIndex) }
		>
			<div class="sticky top-0 z-10 flex items-center gap-2 border-b border-border bg-popover px-3 py-2" role="presentation">
				@lucide.File(ahtempl.Attributes{"class": "size-4 text-muted-foreground"})
				<span class="text-xs font-medium text-muted-foreground">Files</span>
				<span class="ml-auto text-xs text-muted-foreground">↑/↓ navigate · Tab to select</span>
			</div>
			if snapshot.Loading {
				<div class="px-3 py-3 text-xs text-muted-foreground" role="status" aria-live="polite">Loading files...</div>
			} else if fileMentionShowEmpty(snapshot) {
				<div class="px-3 py-3 text-xs text-muted-foreground" role="status" aria-live="polite">{ "No results for “" + snapshot.Query + "”" }</div>
			} else {
				<div class="overflow-y-auto py-1">
					for index, item := range snapshot.Suggestions {
						<button
							id={ fileMentionItemID(item.Path) }
							type="button"
							data-index={ strconv.Itoa(index) }
							class={ fileMentionRowClass(index, snapshot.SelectedIndex) }
							role="option"
							aria-selected={ strconv.FormatBool(index == snapshot.SelectedIndex) }
							data-file-mention-option={ item.Path }
							data-file-mention-type={ item.Type }
							disabled
						>
							if item.Type == "directory" {
								@lucide.Folder(ahtempl.Attributes{"class": "size-3.5 shrink-0 text-blue-400 dark:text-blue-300"})
							} else {
								@lucide.File(ahtempl.Attributes{"class": "size-3.5 shrink-0 text-muted-foreground"})
							}
							<span class="min-w-0 truncate font-mono text-xs">{ fileMentionDisplayPath(item) }</span>
						</button>
					}
				</div>
			}
		</div>
	}
}
