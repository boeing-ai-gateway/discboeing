				<stop offset=".71" stop-color="#6b7fa7"></stop>
				<stop offset=".78" stop-color="#8167a7"></stop>
				<stop offset=".85" stop-color="#9157a7"></stop>
				<stop offset=".93" stop-color="#9b4da7"></stop>
				<stop offset="1" stop-color="#9e4aa7"></stop>
			</linearGradient>
		</defs>
