package parts

// DiscobotWordmark renders the "discobot" text lettering in gradient colour as
// an inline SVG. The viewBox crops to the text column only (x=325 onward),
// keeping the logo icon off-screen so this component is wordmark-only.
//
// Note: the gradient id "discobot-wordmark-gradient" is a static string. If
// this component is ever rendered more than once per page, the ids will collide
// in the DOM and the second instance will lose its gradient fill. Pass a unique
// id suffix through className or extract to a shared <defs> block at that point.
templ DiscobotWordmark(className string, title string) {
	<svg
		viewBox="325 232 761 140"
		xmlns="http://www.w3.org/2000/svg"
		class={ brandImageClass(className, "h-4") }
		role="img"
		aria-label={ discobotTitle(title, defaultDiscobotWordmarkTitle) }
	>
		<title>{ discobotTitle(title, defaultDiscobotWordmarkTitle) }</title>
		<defs>
			<linearGradient
				id="discobot-wordmark-gradient"
				x1="325.3"
				y1="302.9"
				x2="1086.1"
				y2="302.9"
				gradientUnits="userSpaceOnUse"
			>
				<stop offset="0" stop-color="#fdcc11"></stop>
				<stop offset=".04" stop-color="#f9cc13"></stop>
				<stop offset=".09" stop-color="#eecd19"></stop>
				<stop offset=".15" stop-color="#dccf24"></stop>
				<stop offset=".21" stop-color="#c2d334"></stop>
				<stop offset=".28" stop-color="#a1d748"></stop>
				<stop offset=".35" stop-color="#78dc61"></stop>
				<stop offset=".42" stop-color="#47e27f"></stop>
				<stop offset=".49" stop-color="#11e8a0"></stop>
				<stop offset=".53" stop-color="#06eaa7"></stop>
