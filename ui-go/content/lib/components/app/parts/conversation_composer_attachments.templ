package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerAttachments(files []viewmodel.ComposerAttachment) {
	if len(files) > 0 {
		<div role="group" data-slot="input-group-addon" data-align="block-start" class="text-muted-foreground flex h-auto cursor-text items-center justify-center gap-2 py-1.5 text-sm font-medium select-none order-first w-full px-3 pt-3 justify-start flex-wrap gap-1 border-b border-border pb-2" aria-label="Attached files" data-composer-attachments data-composer-attachment-count={ strconv.Itoa(len(files)) }>
			for _, file := range files {
				<div class="inline-flex max-w-[220px] items-center gap-1 rounded-md border border-border bg-background px-2 py-1 text-xs" role="listitem" data-composer-attachment-id={ file.ID }>
					<span class="truncate" title={ file.Filename }>{ file.Filename }</span>
					<button type="button" class="inline-flex size-4 items-center justify-center rounded-sm text-muted-foreground opacity-60 hover:opacity-100" aria-label={ "Remove " + file.Filename } data-composer-attachment-remove={ file.ID } data-on:click__prevent="discobot.composerAttachments.remove(el)">
						@lucide.X(ahtempl.Attributes{"class": "size-3"})
					</button>
				</div>
			}
		</div>
	}
}
