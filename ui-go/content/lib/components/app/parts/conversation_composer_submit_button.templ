package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"
)

templ ConversationComposerSubmitButton(status string, inputEmpty bool, isPending bool, disabled bool) {
	<button
		type={ composerSubmitButtonType(status) }
		class="group focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-2 rounded-md text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 size-8 p-0 shadow-none has-[>svg]:p-0"
		aria-label={ composerSubmitAriaLabel(status, inputEmpty, isPending) }
		disabled?={ disabled }
		data-composer-submit-button
		data-composer-submit-status={ status }
		data-composer-submit-action={ composerSubmitAction(status, inputEmpty, isPending) }
		data-composer-submit-input-empty={ strconv.FormatBool(inputEmpty) }
		data-composer-submit-pending={ strconv.FormatBool(isPending) }
		data-composer-submit-generating={ strconv.FormatBool(composerSubmitIsGenerating(status)) }
		data-composer-submit-disabled={ strconv.FormatBool(disabled) }
		data-composer-submit-plus-on-hover={ strconv.FormatBool(isPending && inputEmpty && !composerSubmitIsGenerating(status)) }
		if composerSubmitIsGenerating(status) {
			data-on:click="@post('/ui/commands/composer-stop')"
		}
	>
		if composerSubmitShowPlus(status, inputEmpty, isPending) {
			@lucide.Plus(ahtempl.Attributes{"class": "hidden size-4 group-hover:block"})
			@lucide.CornerDownLeft(ahtempl.Attributes{"class": "size-4 group-hover:hidden"})
		} else if status == "submitted" {
			@lucide.LoaderCircle(ahtempl.Attributes{"class": "size-4 animate-spin"})
		} else if status == "streaming" {
			@lucide.Square(ahtempl.Attributes{"class": "size-4"})
		} else if status == "error" {
			@lucide.X(ahtempl.Attributes{"class": "size-4"})
		} else {
			@lucide.CornerDownLeft(ahtempl.Attributes{"class": "size-4"})
		}
	</button>
}
