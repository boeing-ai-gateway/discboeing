package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationQueuePanel(expanded bool, entries []viewmodel.PlanEntry) {
	if expanded && len(entries) > 0 {
		<div
			class="mb-2 rounded-lg border border-border bg-background shadow-sm"
			role="region"
			aria-labelledby="conversation-queue-heading"
			data-conversation-queue-panel
			data-conversation-queue-expanded={ strconv.FormatBool(expanded) }
			data-conversation-queue-count={ strconv.Itoa(len(entries)) }
			data-conversation-queue-completed-count={ strconv.Itoa(conversationQueueCompletedCount(entries)) }
		>
			<div id="conversation-queue-heading" class="border-b border-border px-3 py-2 text-xs font-medium text-muted-foreground">
				{ "Todo (" + strconv.Itoa(conversationQueueCompletedCount(entries)) + " completed)" }
			</div>
			<div class="max-h-48 overflow-auto p-1" role="list" aria-label="Todo queue">
				for index, entry := range entries {
					<div
						class={ conversationQueueRowClass(entry.Status) }
						role="listitem"
						data-conversation-queue-entry-id={ entry.ID }
						data-conversation-queue-entry-index={ strconv.Itoa(index) }
						data-conversation-queue-entry-status={ entry.Status }
					>
						if entry.Status == "in_progress" {
							@lucide.LoaderCircle(ahtempl.Attributes{"class": "size-3 animate-spin text-blue-500", "aria-hidden": "true"})
						} else if entry.Status == "completed" {
							<div class="size-3 rounded-full border border-green-500 bg-green-500" aria-hidden="true"></div>
						} else {
							<div class="size-3 rounded-full border border-muted-foreground/50" aria-hidden="true"></div>
						}
						<div class={ conversationQueueTextClass(entry.Status) }>{ conversationQueueEntryText(entry) }</div>
					</div>
				}
			</div>
		</div>
	}
}
