package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	uipopover "github.com/obot-platform/discobot/ui-go/content/lib/components/ui/popover"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerScheduleControl(snapshot viewmodel.ConversationComposerSnapshot) {
	@uipopover.PopoverAttrs(snapshot.ScheduleOpen, ahtempl.Attributes{
		"class": "relative",
		"data-composer-schedule-control": "",
		"data-composer-schedule-open": strconv.FormatBool(snapshot.ScheduleOpen),
		"data-popover-dismiss-url": composerScheduleURL("close"),
	}) {
		@uipopover.PopoverTriggerAttrs(composerScheduleButtonClass(snapshot), composerScheduleDisabled(snapshot), ahtempl.Attributes{
			"title": composerScheduleTitle(snapshot),
			"aria-label": composerScheduleTitle(snapshot),
			"aria-expanded": strconv.FormatBool(snapshot.ScheduleOpen),
			"data-on:click": composerScheduleCommand("toggle"),
		}) {
			@lucide.Clock(ahtempl.Attributes{"class": "size-4"})
		}
		@uipopover.PopoverContentAttrs(snapshot.ScheduleOpen, "top", "end", 4, "absolute right-0 bottom-full mb-2 w-72 p-3", ahtempl.Attributes{
			"data-composer-schedule-popover": "",
		}) {
			<div class="space-y-3" role="group" aria-labelledby="conversation-composer-schedule-heading" data-conversation-prompt-schedule-picker data-current-run-after={ snapshot.ScheduledRunAfter } data-schedule-disabled={ strconv.FormatBool(composerScheduleDisabled(snapshot)) }>
				<div>
					<div id="conversation-composer-schedule-heading" class="text-sm font-medium">Run later</div>
					<div class="text-xs text-muted-foreground">Pick when this prompt becomes eligible.</div>
				</div>
				<div class="grid grid-cols-2 gap-2">
					<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="15" data-on:click={ composerScheduleOffsetCommand(15) } disabled?={ composerScheduleDisabled(snapshot) }>15 min</button>
					<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="60" data-on:click={ composerScheduleOffsetCommand(60) } disabled?={ composerScheduleDisabled(snapshot) }>1 hour</button>
					<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="later" data-schedule-offset-minutes="1440" data-on:click={ composerScheduleOffsetCommand(1440) } disabled?={ composerScheduleDisabled(snapshot) }>1 day</button>
					<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="pause" data-on:click={ composerScheduleCommand("pause") } disabled?={ composerScheduleDisabled(snapshot) }>Pause</button>
				</div>
				<div class="space-y-2">
					<div class="text-xs font-medium text-muted-foreground">Custom time</div>
					<input type="datetime-local" name="schedule_custom_run_after" value={ composerScheduleCustomValue(snapshot) } class="border-input bg-background selection:bg-primary dark:bg-input/30 selection:text-primary-foreground ring-offset-background placeholder:text-muted-foreground flex h-9 w-full min-w-0 rounded-md border px-3 py-1 text-base shadow-xs transition-[color,box-shadow] outline-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive" data-schedule-custom-input disabled?={ composerScheduleDisabled(snapshot) }/>
					<div class="flex justify-between gap-2">
						<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50 border shadow-xs h-6 px-2" data-schedule-action="run-now" data-on:click={ composerScheduleCommand("run-now") } disabled?={ composerScheduleDisabled(snapshot) }>Run now</button>
						<button type="button" class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center gap-1 rounded-md text-xs font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-6 px-2" data-schedule-action="save-custom" data-on:click={ composerScheduleCommand("save-custom") } disabled?={ composerScheduleDisabled(snapshot) }>Save</button>
					</div>
				</div>
			</div>
		}
	}
}
