package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerHooksControl(snapshot viewmodel.ConversationHooksPanelSnapshot) {
	if len(snapshot.Hooks) > 0 {
		<button
			type="button"
			class="inline-flex h-8 items-center gap-1.5 rounded-md px-2 text-xs font-medium text-muted-foreground hover:bg-accent hover:text-accent-foreground"
			aria-expanded={ strconv.FormatBool(snapshot.Expanded) }
			aria-label={ composerHooksControlLabel(snapshot) }
			data-composer-hooks-control
			data-composer-hooks-expanded={ strconv.FormatBool(snapshot.Expanded) }
			data-composer-hooks-count={ strconv.Itoa(len(snapshot.Hooks)) }
			data-composer-hooks-passed-count={ strconv.Itoa(composerHookPassedCount(snapshot.Hooks)) }
			data-composer-hooks-state={ composerHooksControlState(snapshot.Hooks) }
			disabled
		>
			if composerHookHasState(snapshot.Hooks, "running") {
				@lucide.LoaderCircle(ahtempl.Attributes{"class": "size-3.5 animate-spin text-blue-500"})
			} else if composerHookHasState(snapshot.Hooks, "failure") {
				@lucide.TriangleAlert(ahtempl.Attributes{"class": "size-3.5 text-yellow-500"})
			} else {
				@lucide.Zap(ahtempl.Attributes{"class": "size-3.5 text-green-500"})
			}
			<span>{ strconv.Itoa(composerHookPassedCount(snapshot.Hooks)) }</span>
		</button>
	}
}
