package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationComposerQueueControl(expanded bool, entries []viewmodel.PlanEntry) {
	if len(entries) > 0 {
		<button
			type="button"
			class="inline-flex h-8 items-center gap-1.5 rounded-md px-2 text-xs font-medium text-muted-foreground hover:bg-accent hover:text-accent-foreground"
			aria-expanded={ strconv.FormatBool(expanded) }
			aria-label={ composerQueueControlLabel(entries) }
			data-composer-queue-control
			data-composer-queue-expanded={ strconv.FormatBool(expanded) }
			data-composer-queue-count={ strconv.Itoa(len(entries)) }
			data-composer-queue-completed-count={ strconv.Itoa(composerQueueCompletedCount(entries)) }
			disabled
		>
			@lucide.CircleCheck(ahtempl.Attributes{"class": "size-3.5"})
			<span class="text-xs font-medium">{ strconv.Itoa(composerQueueCompletedCount(entries)) + "/" + strconv.Itoa(len(entries)) }</span>
		</button>
	}
}
