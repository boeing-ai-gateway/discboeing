package parts

import (
	"strconv"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ DevErrorOverlay(snapshot viewmodel.DevErrorOverlaySnapshot) {
	if devErrorOverlayVisible(snapshot) {
		<div
			class="fixed right-4 bottom-4 z-[99999] flex max-h-[80vh] w-[min(40rem,calc(100vw-2rem))] flex-col overflow-hidden rounded-lg border border-red-500/70 bg-red-950 text-red-50 shadow-2xl"
			role="region"
			aria-labelledby="dev-error-overlay-title"
			aria-live="assertive"
			data-dev-error-overlay
			data-dev-error-enabled={ strconv.FormatBool(snapshot.Enabled) }
			data-dev-error-count={ strconv.Itoa(len(snapshot.Errors)) }
			data-dev-error-max-count={ devErrorID(maxDevErrors) }
			data-dev-error-copied-id={ devErrorID(snapshot.CopiedID) }
		>
			<div class="flex items-center justify-between gap-4 border-b border-red-500/40 px-4 py-3">
				<div>
					<p id="dev-error-overlay-title" class="text-sm font-semibold">Development errors</p>
					<p class="text-xs text-red-100/80">
						Showing the latest { devErrorID(maxDevErrors) } console and global errors.
					</p>
				</div>
				<button
					type="button"
					class="rounded border border-red-300/40 px-2 py-1 text-xs font-medium hover:bg-red-900 disabled:pointer-events-none disabled:opacity-50"
					aria-label="Clear development errors"
					disabled
					data-dev-error-action="clear"
					data-dev-error-clear
				>
					Clear
				</button>
			</div>
			<div class="overflow-auto p-3" role="list" aria-label="Development errors" data-dev-error-list>
				for index, devError := range snapshot.Errors {
					<div
						class="mb-3 rounded-md border border-red-500/40 bg-red-900/50 p-3 last:mb-0"
						role="listitem"
						aria-labelledby={ devErrorTitleID(devError.ID) }
						data-dev-error-id={ devErrorID(devError.ID) }
						data-dev-error-index={ strconv.Itoa(index) }
						data-dev-error-title={ devError.Title }
						data-dev-error-has-stack={ strconv.FormatBool(devError.Stack != "") }
					>
						<div class="mb-2 flex items-start justify-between gap-3">
							<div>
								<p id={ devErrorTitleID(devError.ID) } class="text-xs font-semibold tracking-wide text-red-100 uppercase" data-dev-error-title-text>
									{ devError.Title }
								</p>
								<pre class="mt-1 whitespace-pre-wrap break-words font-mono text-xs" data-dev-error-message>{ devError.Message }</pre>
							</div>
							<div class="flex shrink-0 gap-2">
								<button
									type="button"
									class="rounded border border-red-300/30 px-2 py-1 text-xs hover:bg-red-900 disabled:pointer-events-none disabled:opacity-50"
									aria-label={ "Copy development error " + devErrorID(devError.ID) }
									disabled
									data-dev-error-action="copy"
									data-dev-error-copy={ devErrorID(devError.ID) }
									data-dev-error-copied={ strconv.FormatBool(snapshot.CopiedID == devError.ID) }
								>
									{ devErrorCopyLabel(snapshot, devError.ID) }
								</button>
								<button
									type="button"
									class="rounded border border-red-300/30 px-2 py-1 text-xs hover:bg-red-900 disabled:pointer-events-none disabled:opacity-50"
									aria-label={ "Dismiss development error " + devErrorID(devError.ID) }
									disabled
									data-dev-error-action="dismiss"
									data-dev-error-dismiss={ devErrorID(devError.ID) }
								>
									Dismiss
								</button>
							</div>
						</div>
						if devError.Stack != "" {
							<pre class="mt-2 whitespace-pre-wrap break-words border-t border-red-500/30 pt-2 font-mono text-[11px] text-red-100/80" data-dev-error-stack>{ devError.Stack }</pre>
						}
					</div>
				}
			</div>
		</div>
	}
}
