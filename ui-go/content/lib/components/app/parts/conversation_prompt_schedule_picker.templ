package parts

import (
	"strconv"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationPromptSchedulePicker(entry viewmodel.QueuedPrompt) {
	<div
		class="space-y-3"
		role="group"
		aria-labelledby="conversation-prompt-schedule-heading"
		data-conversation-prompt-schedule-picker
		data-current-run-after={ entry.RunAfter }
		data-schedule-disabled={ strconv.FormatBool(entry.Saving) }
	>
		<div>
			<div id="conversation-prompt-schedule-heading" class="text-sm font-medium">Run later</div>
			<div class="text-xs text-muted-foreground">Pick when this prompt becomes eligible.</div>
		</div>
		<div class="grid grid-cols-2 gap-2">
			<button type="button" class="h-7 rounded-md border border-input px-2 text-xs font-medium" data-schedule-action="later" data-schedule-offset-minutes="15" data-on:click={ queuedPromptScheduleCommand(entry.ID, "later", "15") } disabled?={ entry.Saving }>15 min</button>
			<button type="button" class="h-7 rounded-md border border-input px-2 text-xs font-medium" data-schedule-action="later" data-schedule-offset-minutes="60" data-on:click={ queuedPromptScheduleCommand(entry.ID, "later", "60") } disabled?={ entry.Saving }>1 hour</button>
			<button type="button" class="h-7 rounded-md border border-input px-2 text-xs font-medium" data-schedule-action="later" data-schedule-offset-minutes="1440" data-on:click={ queuedPromptScheduleCommand(entry.ID, "later", "1440") } disabled?={ entry.Saving }>1 day</button>
			<button type="button" class="h-7 rounded-md border border-input px-2 text-xs font-medium" data-schedule-action="pause" data-on:click={ queuedPromptCommand(entry.ID, "pause") } disabled?={ entry.Saving }>Pause</button>
		</div>
		<div class="space-y-2">
			<label for="queued-prompt-custom-run-after" class="text-xs font-medium text-muted-foreground">Custom time</label>
			<input
				id="queued-prompt-custom-run-after"
				type="datetime-local"
				value={ entry.RunAfter }
				class="h-9 w-full rounded-md border border-input bg-background px-3 text-sm"
				data-schedule-custom-input
				disabled?={ entry.Saving }
			/>
			<div class="flex justify-between gap-2">
				<button type="button" class="h-7 rounded-md border border-input px-2 text-xs font-medium" data-schedule-action="run-now" data-on:click={ queuedPromptCommand(entry.ID, "run-now") } disabled?={ entry.Saving }>Run now</button>
				<button type="button" class="h-7 rounded-md bg-primary px-2 text-xs font-medium text-primary-foreground" data-schedule-action="save-custom" data-on:click={ queuedPromptCommand(entry.ID, "save-custom") } disabled?={ entry.Saving }>Save</button>
			</div>
		</div>
	</div>
}
