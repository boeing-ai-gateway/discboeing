package parts

import "strconv"

templ ConversationComposerTextarea(draft string, disabled bool, attachmentCount int) {
	<textarea
		id="conversation-composer-textarea"
		name="prompt"
		rows="2"
		data-slot="input-group-control"
		class="border-input placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex field-sizing-content min-h-16 w-full bg-transparent px-3 text-base transition-[color,box-shadow] outline-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm flex-1 resize-none rounded-none border-0 py-3 shadow-none focus-visible:ring-0 dark:bg-transparent max-h-48 transition-all"
		placeholder="Type a message, @file, /command, or ↑ for history"
		aria-label="Message"
		autocomplete="off"
		spellcheck="true"
		disabled?={ disabled }
		data-composer-textarea
		data-composer-draft-empty={ strconv.FormatBool(draft == "") }
		data-composer-draft-length={ strconv.Itoa(len(draft)) }
		data-composer-attachment-count={ strconv.Itoa(attachmentCount) }
		data-composer-submit-on-enter="true"
		data-composer-shift-enter-newline="true"
		data-composer-backspace-removes-last-attachment={ strconv.FormatBool(attachmentCount > 0) }
		data-composer-paste-files="true"
		data-composer-file-mentions="true"
		data-composer-slash-commands="true"
		data-composer-prompt-history="true"
	>{ draft }</textarea>
}
