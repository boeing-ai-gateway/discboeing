package parts

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationSlashCommandDropdown(snapshot viewmodel.SlashCommandDropdownSnapshot) {
	if slashCommandShouldRender(snapshot) {
		<div
			id="conversation-slash-command-dropdown"
			class="absolute right-0 bottom-full left-0 z-50 mb-1 flex max-h-64 flex-col overflow-hidden rounded-lg border border-border bg-popover shadow-lg"
			role="listbox"
			aria-label="Command suggestions"
			aria-activedescendant={ slashCommandActiveID(snapshot) }
			data-conversation-slash-command-dropdown
			data-query={ snapshot.Query }
			data-open={ strconv.FormatBool(snapshot.Open) }
			data-loading={ strconv.FormatBool(snapshot.Loading) }
			data-command-count={ strconv.Itoa(len(slashCommandSuggestions(snapshot))) }
			data-selected-index={ strconv.Itoa(snapshot.SelectedIndex) }
		>
			<div class="sticky top-0 z-10 flex items-center gap-2 border-b border-border bg-popover px-3 py-2" role="presentation">
				@lucide.Terminal(ahtempl.Attributes{"class": "size-4 text-muted-foreground"})
				<span class="text-xs font-medium text-muted-foreground">Commands</span>
				<span class="ml-auto text-xs text-muted-foreground">↑/↓ navigate · Tab to select</span>
			</div>
			if snapshot.Loading {
				<div class="px-3 py-3 text-xs text-muted-foreground" role="status" aria-live="polite">
					Loading commands...
				</div>
			} else if slashCommandShowEmpty(snapshot) {
				<div class="px-3 py-3 text-xs text-muted-foreground" role="status" aria-live="polite">
					{ slashCommandEmptyMessage(snapshot.Query) }
				</div>
			} else {
				<div class="overflow-y-auto py-1">
					for index, command := range slashCommandSuggestions(snapshot) {
						<button
							id={ slashCommandItemID(command.Name) }
							type="button"
							data-index={ slashCommandIndex(index) }
							data-command={ command.Name }
							data-command-description={ command.Description }
							role="option"
							aria-selected={ strconv.FormatBool(index == snapshot.SelectedIndex) }
							class={ slashCommandItemClass(index, snapshot.SelectedIndex) }
						>
							@lucide.Terminal(ahtempl.Attributes{"class": "mt-0.5 size-3.5 shrink-0 text-muted-foreground"})
							<div class="min-w-0 flex-1">
								<div class="truncate font-mono text-xs">/{ command.Name }</div>
								<div class="line-clamp-2 text-xs text-muted-foreground">
									{ command.Description }
								</div>
							</div>
						</button>
					}
				</div>
			}
		</div>
	}
}
