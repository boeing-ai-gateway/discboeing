package app

templ ThreadStateBadge(state string, className string) {
	if threadStateLabel(state) != "" {
		<span class={ "inline-flex shrink-0 items-center rounded-full border px-1.5 py-0.5 text-[10px] font-medium " + threadStateTone(state) + " " + className }>
			{ threadStateLabel(state) }
		</span>
	}
}
