package app

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"
	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationCredentialsControl(snapshot viewmodel.ConversationCredentialsSnapshot) {
	<details class="desktop-no-drag relative" data-conversation-credentials>
		<summary class="inline-flex h-6 cursor-default list-none items-center gap-1.5 rounded-md px-2 text-xs hover:bg-accent hover:text-accent-foreground">
			@lucide.KeyRound(ahtempl.Attributes{"class": "size-3.5 " + credentialKeyTone(visibleCredentialCount(snapshot))})
			<span class={ credentialCountClass(visibleCredentialCount(snapshot)) } aria-hidden={ strconv.FormatBool(visibleCredentialCount(snapshot) <= 1) }>
				{ strconv.Itoa(visibleCredentialCount(snapshot)) }
			</span>
		</summary>
		<div class="absolute bottom-full left-0 z-50 mb-2 w-[28rem] max-w-[calc(100vw-1rem)] rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md">
			<div class="px-2 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-muted-foreground">Session credentials</div>
			<div class="px-2 pb-1 text-xs text-muted-foreground">
				Credential visibility for this session. Toggle which runtimes can use each credential.
			</div>
			if snapshot.Loading {
				<div class="px-2 py-3 text-sm text-muted-foreground">Loading…</div>
			} else if len(snapshot.Assignments) == 0 {
				<div class="px-2 py-3 text-sm text-muted-foreground">No credentials</div>
			} else {
				<div class="space-y-1.5 p-2">
					for _, assignment := range snapshot.Assignments {
						<div class="rounded-md border border-border/70 bg-background/70 px-2.5 py-2">
							<div class="flex items-start gap-2">
								<div class="min-w-0 flex-1">
									<div class="truncate text-sm font-medium">{ assignment.Name }</div>
									if len(assignment.Uses) > 0 {
										<button type="button" class="mt-1 inline-flex items-center gap-1 rounded-sm text-[11px] text-muted-foreground hover:text-foreground" disabled>
											@lucide.ChevronDown(ahtempl.Attributes{"class": "size-3"})
											<span>{ credentialUsesLabel(len(assignment.Uses)) }</span>
										</button>
									}
								</div>
								<div class="flex items-center gap-1">
									<button type="button" title="Tools" aria-label="Toggle tools visibility" class={ credentialRuntimeClass(assignment.Visibility.Tools, assignment.Inactive) } disabled>
										@lucide.Hammer(ahtempl.Attributes{"class": "size-3.5"})
									</button>
									<button type="button" title="Console / SSH / IDE" aria-label="Toggle console SSH IDE visibility" class={ credentialRuntimeClass(assignment.Visibility.Console, assignment.Inactive) } disabled>
										@lucide.Terminal(ahtempl.Attributes{"class": "size-3.5"})
									</button>
									<button type="button" title="Services" aria-label="Toggle services visibility" class={ credentialRuntimeClass(assignment.Visibility.Services, assignment.Inactive) } disabled>
										@lucide.Server(ahtempl.Attributes{"class": "size-3.5"})
									</button>
									<button type="button" title="Hooks" aria-label="Toggle hooks visibility" class={ credentialRuntimeClass(assignment.Visibility.Hooks, assignment.Inactive) } disabled>
										@lucide.Webhook(ahtempl.Attributes{"class": "size-3.5"})
									</button>
									<div class="ml-1 border-l border-border/70 pl-2">
										<button type="button" class={ credentialAllVisibilityClass(assignment) } aria-label="Toggle all session credential visibility" aria-checked={ credentialAllVisibilityAria(assignment) } disabled>
											if credentialAllVisibilityAria(assignment) == "mixed" {
												<span class="h-0.5 w-2.5 rounded-full bg-current"></span>
											} else if credentialAllVisibilityAria(assignment) == "true" {
												<span class="size-2.5 rounded-sm bg-current"></span>
											}
										</button>
									</div>
								</div>
							</div>
							if len(assignment.Uses) > 0 {
								<div class="mt-2 w-full space-y-1.5">
									for _, use := range assignment.Uses {
										<div class={ credentialUseClass(use) }>
											<div class="min-w-0 flex-1">
												<div class="whitespace-normal break-words text-[12px] font-medium">{ use.Description }</div>
												if use.Timing != "" {
													<div class="text-[11px] text-muted-foreground">{ use.Timing }</div>
												}
											</div>
											<button type="button" class="inline-flex size-6 shrink-0 items-center justify-center rounded-sm text-muted-foreground hover:bg-background hover:text-foreground" aria-label="Remove authorized use" title="Remove authorized use" disabled>
												@lucide.Trash2(ahtempl.Attributes{"class": "size-3.5"})
											</button>
										</div>
									}
								</div>
							}
						</div>
					}
				</div>
			}
			<div class="border-t border-border p-1">
				<button type="button" class="flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-sm text-muted-foreground hover:bg-accent hover:text-accent-foreground" disabled>
					@lucide.Settings(ahtempl.Attributes{"class": "size-3.5"})
					Manage credentials
				</button>
			</div>
		</div>
	</details>
}
