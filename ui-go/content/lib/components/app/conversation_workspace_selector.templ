package app

import (
	"strconv"

	ahtempl "github.com/a-h/templ"
	lucide "github.com/bryanvaz/go-templ-lucide-icons/icons"

	"github.com/obot-platform/discobot/ui-go/content/lib/viewmodel"
)

templ ConversationWorkspaceSelector(snapshot viewmodel.ConversationWorkspaceSelectorSnapshot) {
	<div class={ workspaceSelectorClass(snapshot.FullWidth) } data-conversation-workspace-selector data-signals:_workspace-suggestions-open__ifmissing="true" data-signals:_workspace-source-input__ifmissing={ strconv.Quote(snapshot.SourceInput) } data-on:pointerdown__outside="$_workspaceSuggestionsOpen = false">
		if snapshot.RequiresInput {
			<button type="button" class="-m-1 inline-flex items-center justify-center rounded-sm p-1 text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" aria-label="Return to workspace dropdown" title="Return to workspace dropdown" data-workspace-reset data-on:click__prevent__stop="discobot.workspaceSelector.reset(el)">
				@WorkspaceIcon(workspaceIconSource(snapshot), "size-4")
			</button>
			<div class={ "relative " + workspaceInputWidthClass(snapshot.FullWidth) }>
				<div class="flex items-center gap-1.5">
					<input
						id="session-setup-source-inline"
						class={ "border-input bg-background selection:bg-primary dark:bg-input/30 selection:text-primary-foreground ring-offset-background placeholder:text-muted-foreground flex h-8 min-w-0 rounded-md border px-3 py-1 text-xs shadow-xs transition-[color,box-shadow] outline-none disabled:cursor-not-allowed disabled:opacity-50 focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive flex-1 " + workspaceInputWidthClass(snapshot.FullWidth) }
						placeholder={ workspaceSourcePlaceholder(snapshot.SourceType) }
						aria-autocomplete="list"
						aria-expanded={ strconv.FormatBool(len(snapshot.Suggestions) > 0) }
						aria-busy={ strconv.FormatBool(snapshot.Validating) }
						aria-invalid={ strconv.FormatBool(workspaceInputInvalid(snapshot)) }
						data-bind:_workspace-source-input
						data-workspace-source-input
						data-workspace-source-type={ snapshot.SourceType }
						data-attr:aria-expanded="$_workspaceSuggestionsOpen && !!el.closest('[data-conversation-workspace-selector]')?.querySelector('[data-workspace-suggestions]')"
						data-on:focus="$_workspaceSuggestionsOpen = true"
						data-on:input="$_workspaceSuggestionsOpen = true; discobot.workspaceSelector.input(el)"
						data-on:keydown="discobot.workspaceSelector.keydown(el, evt)"
					/>
					if snapshot.Validating {
						@lucide.LoaderCircle(ahtempl.Attributes{"class": "size-3.5 animate-spin text-muted-foreground", "aria-hidden": "true"})
					}
					if snapshot.SourceType == "local" {
						<button type="button" class="inline-flex size-8 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-accent-foreground" aria-label="Choose local directory" title="Choose local directory" disabled>
							@lucide.FolderOpen(ahtempl.Attributes{"class": "size-4"})
						</button>
					}
				</div>
				if len(snapshot.Suggestions) > 0 || workspaceValidationError(snapshot) != "" {
					<div class={ "absolute right-0 top-full z-50 mt-1 max-h-56 overflow-y-auto rounded-md border border-border bg-popover shadow-lg " + workspaceInputWidthClass(snapshot.FullWidth) } role="listbox" data-workspace-suggestions data-show="$_workspaceSuggestionsOpen">
						for index, suggestion := range snapshot.Suggestions {
							<button type="button" class={ workspaceSuggestionClass(workspaceSuggestionSelected(snapshot, index), suggestion.Valid) } role="option" aria-selected={ strconv.FormatBool(workspaceSuggestionSelected(snapshot, index)) } data-workspace-suggestion={ suggestion.Value } data-on:click="$_workspaceSourceInput = el.dataset.workspaceSuggestion || ''; discobot.workspaceSelector.suggestion(el)">
								<span class="truncate font-mono">{ suggestion.Value }</span>
								if suggestion.Valid {
									@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
								}
							</button>
						}
						if workspaceValidationError(snapshot) != "" {
							if len(snapshot.Suggestions) > 0 {
								<div class="mx-3 border-t border-border"></div>
							}
							<div class="flex gap-2 px-3 py-2 text-xs text-destructive" role="alert">
								@lucide.CircleAlert(ahtempl.Attributes{"class": "mt-0.5 size-3.5 shrink-0"})
								<span class="min-w-0 break-words">{ workspaceValidationError(snapshot) }</span>
							</div>
						}
					</div>
				}
			</div>
		} else {
			@WorkspaceIcon(workspaceIconSource(snapshot), "size-4 text-muted-foreground")
			<div class={ "group/native-select relative has-[select:disabled]:opacity-50 " + workspaceInputWidthClass(snapshot.FullWidth) } data-slot="native-select-wrapper" data-workspace-select-wrapper>
				<select
					id="session-setup-workspace-inline"
					class={ "border-input text-foreground placeholder:text-muted-foreground selection:bg-primary selection:text-primary-foreground dark:bg-input/30 dark:hover:bg-input/50 h-8 min-w-0 appearance-none rounded-md border bg-transparent px-3 py-2 pe-9 text-xs shadow-xs transition-[color,box-shadow] outline-none disabled:pointer-events-none disabled:cursor-not-allowed focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive " + workspaceInputWidthClass(snapshot.FullWidth) }
					disabled?={ snapshot.Loading }
					data-slot="native-select"
					data-workspace-select
					data-on:focus="discobot.workspaceSelector.rememberSelectValue(el)"
					data-on:pointerdown="discobot.workspaceSelector.rememberSelectValue(el)"
					data-on:change="$_workspaceSourceInput = ''; discobot.workspaceSelector.option(el)"
				>
					if len(snapshot.Workspaces) > 0 {
						<optgroup label="Existing workspaces">
							for _, workspace := range snapshot.Workspaces {
								<option value={ workspaceOptionValue(workspace) } selected?={ snapshot.SelectedOption == workspaceOptionValue(workspace) }>
									{ workspace.Label }
								</option>
							}
						</optgroup>
					}
					<optgroup label="Create new">
						<option value="new-workspace" selected?={ snapshot.SelectedOption == "new-workspace" }>Create New Workspace</option>
						<option value="local-directory" selected?={ snapshot.SelectedOption == "local-directory" }>Local Directory</option>
						<option value="git-repo" selected?={ snapshot.SelectedOption == "git-repo" }>GitHub Repo</option>
					</optgroup>
				</select>
				@lucide.ChevronDown(ahtempl.Attributes{"class": "text-muted-foreground pointer-events-none absolute end-3.5 top-1/2 size-4 -translate-y-1/2 opacity-50 select-none", "aria-hidden": "true", "data-slot": "native-select-icon"})
			</div>
		}
	</div>
	if snapshot.ShowBranchSelector {
		<details class="desktop-no-drag relative">
			<summary class="inline-flex size-8 list-none items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-accent-foreground" title={ snapshot.Branch }>
				@lucide.GitBranch(ahtempl.Attributes{"class": "size-4"})
			</summary>
			<div class="absolute bottom-full right-0 z-50 mb-1 w-56 rounded-md border border-border bg-popover p-1 shadow-md">
				<button type="button" class="flex w-full items-center justify-between rounded-sm px-2 py-1.5 text-sm hover:bg-accent" disabled>
					<span>No branch</span>
					if snapshot.Branch == "" {
						@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
					}
				</button>
				<div class="my-1 h-px bg-border"></div>
				for _, branch := range snapshot.Branches {
					<button type="button" class="flex w-full items-center justify-between rounded-sm px-2 py-1.5 text-sm hover:bg-accent" disabled>
						<span class="truncate">{ branch }</span>
						if snapshot.Branch == branch {
							@lucide.Check(ahtempl.Attributes{"class": "size-3.5 text-primary"})
						}
					</button>
				}
			</div>
		</details>
	}
}
