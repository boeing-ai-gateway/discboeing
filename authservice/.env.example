# Discobot Auth Service
# Copy to .env and fill in the provider credentials you want to enable.

# Server
PORT=3010

# Public hostname or full URL used as the issuer and redirect base.
# For local development, localhost is fine.
PUBLIC_HOSTNAME=localhost:3010

# Database
# Defaults to XDG data dir, e.g. ~/.local/share/discobot/discobot-auth.db
DATABASE_DSN=sqlite3://~/.local/share/discobot/discobot-auth.db
# DATABASE_DSN=postgres://user:pass@localhost:5432/discobot_auth?sslmode=disable

# Browser session / OIDC lifetimes
BROWSER_SESSION_TTL=24h
AUTHORIZATION_CODE_TTL=5m
ACCESS_TOKEN_TTL=15m

# GitHub OAuth App
# Homepage URL: http://localhost:3010
# Authorization callback URL: http://localhost:3010/login/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth Client (Web application)
# Authorized redirect URI: http://localhost:3010/login/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
