# Discobot Auth Service - rolling deployment example
#
# Copy to .env and replace the placeholder values.
#
# Note: authservice does not currently accept a separate encryption/signing secret
# via environment variable. It generates an Ed25519 signing key automatically and
# stores it in the configured database on first start.
#
# If you ever need a strong 32-byte hex secret for a future config value, this
# works on a basic Ubuntu VM with OpenSSL installed:
#   openssl rand -hex 32
#
# Optional AES-256-GCM key for encrypting signing keys at rest in the database.
# Generate with:
#   openssl rand -hex 32
# If unset, authservice uses a built-in insecure fallback key and logs a warning.
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# Public site address for Caddy.
# Use a real public hostname (no scheme) so Caddy can obtain ACME certificates
# automatically and redirect HTTP to HTTPS on ports 80/443.
# Example: auth.example.com
CADDY_SITE_ADDRESS=REPLACE_WITH_PUBLIC_HOSTNAME

# Server
PORT=3010

# Public hostname or full external URL used as the issuer and redirect base.
# Keep this on HTTPS in production so cookies stay secure.
PUBLIC_HOSTNAME=https://REPLACE_WITH_PUBLIC_HOSTNAME

# PostgreSQL database used by the rolling deployment.
POSTGRES_DB=authservice
POSTGRES_USER=authservice
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD
DATABASE_DSN=postgres://authservice:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/authservice?sslmode=disable

# Browser session / OIDC lifetimes
BROWSER_SESSION_TTL=24h
AUTHORIZATION_CODE_TTL=5m
ACCESS_TOKEN_TTL=15m

# Configure at least one upstream provider.
# GitHub OAuth App
# Homepage URL: https://REPLACE_WITH_PUBLIC_HOSTNAME
# Authorization callback URL: https://REPLACE_WITH_PUBLIC_HOSTNAME/login/github/callback
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET

# Google OAuth Client (Web application)
# Authorized redirect URI: https://REPLACE_WITH_PUBLIC_HOSTNAME/login/google/callback
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
