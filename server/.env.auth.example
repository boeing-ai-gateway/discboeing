# Discobot Server - With Authentication
# Copy this file to .env and fill in your secrets
#
# Usage: cp .env.auth.example .env

# Server
PORT=3001

# Database (SQLite for local, PostgreSQL for production)
DATABASE_DSN=sqlite3://./discobot.db
# DATABASE_DSN=postgres://user:pass@localhost:5432/discobot?sslmode=disable

# Authentication enabled - requires OIDC setup
AUTH_ENABLED=true

# Encryption key for credentials (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Auth cookie SameSite policy: lax, strict, or none
# AUTH_COOKIE_SAMESITE=lax

# Public hostname or URL for external redirects. Defaults to localhost:{PORT}
# PUBLIC_HOSTNAME=discobot.example.com

# CORS
# Supports wildcards: http://*.localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://*.localhost:3000,http://*.localhost:3001

# Workspace directory
WORKSPACE_DIR=./workspaces

# Sandbox Providers
# Enable local provider (runs agent directly in workspace without containers)
# Default: false (only Docker provider is enabled)
# LOCAL_PROVIDER_ENABLED=true
# LOCAL_AGENT_BINARY=obot-agent-api

# For github-git credential provider
# GITHUB_OAUTH_CLIENT_ID=

# Generic OIDC login (optional, preferred for Discobot login)
# Example for Google testing:
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_BACKCHANNEL_BASE_URL=
# OIDC_CLIENT_ID=dynamic
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid,email,profile
OIDC_ISSUER_URL=
OIDC_BACKCHANNEL_BASE_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid,email,profile

# AI Provider OAuth Client IDs (optional, for credential flows)
# These have sensible defaults, only override if needed
# ANTHROPIC_CLIENT_ID=
# GITHUB_COPILOT_CLIENT_ID=
# CODEX_CLIENT_ID=
