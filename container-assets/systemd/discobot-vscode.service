[Unit]
Description=Discobot VS Code socket proxy
Requires=discobot-vscode.socket
Wants=discobot-vscode-backend.service
After=discobot-vscode-backend.service

[Service]
Type=notify
ExecStartPre=/bin/bash -lc 'for i in {1..200}; do exec 3<>/dev/tcp/127.0.0.1/13338 && exec 3>&- && exit 0; sleep 0.1; done; exit 1'
ExecStart=/usr/lib/systemd/systemd-socket-proxyd 127.0.0.1:13338
