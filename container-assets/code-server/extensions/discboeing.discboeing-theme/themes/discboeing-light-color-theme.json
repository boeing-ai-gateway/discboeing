	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#737373"
			}
		},
		{
			"scope": ["string", "markup.inline.raw"],
			"settings": {
				"foreground": "#15803d"
			}
		},
		{
			"scope": [
				"keyword",
				"storage",
				"storage.type",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#2563eb"
			}
		},
		{
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#1d4ed8"
			}
		},
		{
			"scope": ["entity.name.type", "support.type", "support.class"],
			"settings": {
				"foreground": "#b45309"
			}
		},
		{
			"scope": ["constant", "constant.numeric", "boolean"],
			"settings": {
				"foreground": "#c2410c"
			}
		},
		{
			"scope": ["variable.parameter", "meta.definition.variable"],
			"settings": {
				"foreground": "#262626"
			}
		},
		{
			"scope": ["entity.name.tag", "meta.tag"],
			"settings": {
				"foreground": "#2563eb"
			}
		},
		{
			"scope": ["entity.other.attribute-name"],
			"settings": {
				"foreground": "#c2410c"
			}
		},
		{
			"scope": ["invalid", "invalid.illegal"],
			"settings": {
				"foreground": "#ffffff",
				"background": "#dc2626"
			}
		}
	]
}
