	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#737373"
			}
		},
		{
			"scope": ["string", "markup.inline.raw"],
			"settings": {
				"foreground": "#4ade80"
			}
		},
		{
			"scope": [
				"keyword",
				"storage",
				"storage.type",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#60a5fa"
			}
		},
		{
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#93c5fd"
			}
		},
		{
			"scope": ["entity.name.type", "support.type", "support.class"],
			"settings": {
				"foreground": "#fbbf24"
			}
		},
		{
			"scope": ["constant", "constant.numeric", "boolean"],
			"settings": {
				"foreground": "#fb923c"
			}
		},
		{
			"scope": ["variable.parameter", "meta.definition.variable"],
			"settings": {
				"foreground": "#ededed"
			}
		},
		{
			"scope": ["entity.name.tag", "meta.tag"],
			"settings": {
				"foreground": "#60a5fa"
			}
		},
		{
			"scope": ["entity.other.attribute-name"],
			"settings": {
				"foreground": "#fbbf24"
			}
		},
		{
			"scope": ["invalid", "invalid.illegal"],
			"settings": {
				"foreground": "#ffffff",
				"background": "#ef4444"
			}
		}
	]
