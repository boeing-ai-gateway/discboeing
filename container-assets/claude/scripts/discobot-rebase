#!/usr/bin/env bash
#---
# name: discobot-rebase
# description: Rebase session changes onto the tracked upstream branch
# discobot-ui: true
# discobot-label: Rebase
# discobot-icon: git-branch
# discobot-group: Git
# discobot-order: 20
#---
set -euo pipefail

cd /home/discobot/workspace

print_section() {
	local title=$1
	shift
	echo "## ${title}"
	echo '```text'
	if "$@"; then
		:
	else
		local status=$?
		echo "(command exited with status ${status})"
	fi
	echo '```'
	echo
}

upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)
if [[ -z "$upstream" ]]; then
	echo "Discobot rebase could not start because no upstream branch is configured for the current branch." >&2
	echo >&2
	print_section "git status --short --branch" git status --short --branch >&2 || true
	exit 1
fi

remote_name=${upstream%%/*}

echo "Fetching ${remote_name} before rebasing onto ${upstream}..."
git fetch "$remote_name"

echo "Running non-interactive rebase onto ${upstream}..."
if ! GIT_EDITOR=true git rebase --autostash "$upstream"; then
	echo >&2
	echo "Discobot rebase failed while rebasing onto ${upstream}." >&2
	echo "If there are conflicts, explain them clearly to the user, resolve them, then continue with GIT_EDITOR=true git rebase --continue. If the user wants to stop, use git rebase --abort." >&2
	echo >&2
	echo "## git status --short --branch" >&2
	git status --short --branch >&2 || true
	echo >&2
	echo "## conflicted files" >&2
	git diff --name-only --diff-filter=U >&2 || true
	exit 1
fi

cat <<EOF
Discobot rebase completed successfully.

This slash command already fetched ${remote_name}, rebased the current branch
onto ${upstream}, and gathered the post-rebase git state for you.

Summarize the result for the user and mention any important follow-up if needed.

EOF

print_section "git status --short --branch" git status --short --branch
print_section "git log --oneline -5" git log --oneline -5
