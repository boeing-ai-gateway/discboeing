{
  "name": "@discobot/ui-go2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "go run github.com/air-verse/air@latest -c .air.toml",
    "assets:build": "pnpm css:build",
    "css:build": "tailwindcss -i ./styles/app.css -o ./static/app.css",
    "generate": "go run github.com/a-h/templ/cmd/templ@v0.3.1020 generate",
    "build": "pnpm assets:build && pnpm generate && go build -o ./build/ui-go2 ./cmd/ui-go2",
    "check": "pnpm assets:build && pnpm generate && go test ./...",
    "check:fix": "pnpm assets:build && pnpm generate && gofmt -w ."
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "tailwindcss": "4.2.4"
  }
}
