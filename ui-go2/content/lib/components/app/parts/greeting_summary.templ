package parts

import (
	"fmt"

	"github.com/obot-platform/discobot/ui-go2/content/lib/viewmodel"
)

templ GreetingSummary(greeting viewmodel.GreetingSnapshot) {
	<p class="text-sm text-muted-foreground">
		View state was passed from Go: <span class="font-medium text-foreground">{ greeting.Subject }</span> has been greeted
		<span class="font-medium text-foreground">{ fmt.Sprint(greeting.Count) }</span> times.
	</p>
}
