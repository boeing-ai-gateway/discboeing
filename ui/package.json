{
	"name": "@discobot/ui-redesign",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3100 --strictPort",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview --port 3100 --strictPort",
		"format": "pnpm exec prettier . --write",
		"format:check": "pnpm exec prettier . --check",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"check": "pnpm format:check && pnpm lint && pnpm typecheck",
		"check:fix": "pnpm format && pnpm lint:fix && pnpm typecheck",
		"generate:api-types": "openapi-typescript ../server/api/openapi.json -o src/lib/api-types.generated.ts && prettier src/lib/api-types.generated.ts --write",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"test:e2e:live": "DISCOBOT_LIVE_E2E=1 DISCOBOT_LIVE_E2E_API_ROOT=http://localhost:3001/api vitest run src/lib/context/test/session-events.e2e.vitest.ts"
	},
	"dependencies": {
		"@fontsource/geist-sans": "^5.2.5",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@novnc/novnc": "^1.7.0",
		"@pierre/diffs": "^1.2.5",
		"@sentry/sveltekit": "^10.55.0",
		"@streamdown/cjk": "^1.0.3",
		"@streamdown/code": "^1.1.1",
		"@streamdown/math": "^1.0.2",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"ai": "^6.0.193",
		"clsx": "latest",
		"ghostty-web": "^0.4.0",
		"katex": "^0.16.45",
		"marked": "^18.0.4",
		"monaco-editor": "0.55.1",
		"nanoid": "^5.1.11",
		"rehype-harden": "^1.1.8",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"remend": "^1.3.0",
		"simple-icons": "^16.22.0",
		"sortablejs": "^1.15.7",
		"svelte": "latest",
		"tailwind-merge": "latest",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"yaml": "^2.9.0",
		"zod": "latest"
	},
	"devDependencies": {
		"@eslint/js": "latest",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-static": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "latest",
		"@tailwindcss/vite": "latest",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.9.1",
		"@types/sortablejs": "^1.15.9",
		"bits-ui": "^2.18.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "latest",
		"eslint-plugin-svelte": "latest",
		"formsnap": "^2.0.1",
		"globals": "latest",
		"jsdom": "^29.1.1",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"openapi-typescript": "^7.13.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte-check": "latest",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "latest",
		"typescript": "latest",
		"typescript-eslint": "latest",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "latest",
		"vitest": "^4.1.8"
	}
}
